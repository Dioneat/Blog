@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Authorization
@using Radzen
@using Radzen.Blazor
@attribute [Authorize]

<RadzenComponents @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />

<RadzenLayout style="min-height: 100vh;">
    
    <AdminSidebarMenu />

    <RadzenBody class="admin-body">
        <div class="rz-p-2 rz-p-md-4">
            @Body
        </div>
    </RadzenBody>
    
</RadzenLayout>

<style>
    .admin-body {
        padding-top: 70px !important;
        background-color: #f4f6f9;
    }

    @@media (max-width: 768px) {
        .admin-sidebar.rz-sidebar-expanded {
            width: 100vw !important;
        }

        .admin-sidebar {
            top: 0 !important;
            padding-top: 60px !important;
            border-right: none !important;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
            z-index: 1040 !important;
            background-color: var(--rz-base-background-color);
        }
            .admin-sidebar .rz-navigation-item-link {
                padding: 20px 25px !important;
                font-size: 1.15rem !important;
            }
        
            .admin-sidebar .rz-navigation-item-icon {
                font-size: 1.5rem !important;
            }
    }
</style>