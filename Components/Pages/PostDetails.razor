@page "/blog/{Id:int}/{Slug?}"
@using Blog10.Models
@using Blog10.Services
@using System.Text.Json
@inject IBlogService BlogService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<PageTitle>@(post?.Title ?? "Загрузка...") | Елена Тимофеева</PageTitle>

@if (post == null)
{
    <div class="loader-container">
        <div class="spinner"></div>
        <p>Загружаем полезную информацию...</p>
    </div>
}
else
{
    <HeadContent>
        <meta name="description" content="@post.ShortDescription" />
        <meta property="og:title" content="@post.Title" />
        <meta property="og:description" content="@post.ShortDescription" />
        <meta property="og:image" content="@GetAbsoluteImageUrl(post.CoverImageUrl)" />
    </HeadContent>

    <div class="post-wrapper">
        <div class="post-layout">
            
            <div class="post-main">
                
                <nav class="post-nav">
                    <a href="/blog" class="back-link">
                        <i class="fa-solid fa-arrow-left"></i> Назад в блог
                    </a>
                </nav>

                <div class="post-header-content">
                    <div class="post-meta-top">
                        @if (post.Tags != null && post.Tags.Any())
                        {
                            @foreach (var tag in post.Tags)
                            {
                                <a href="/blog?Category=@Uri.EscapeDataString(tag)" class="post-tag" style="text-decoration: none; cursor: pointer; transition: 0.3s;">
                                    #@tag
                                </a>
                            }
                        }
                        <span class="post-date">
                            <i class="fa-regular fa-calendar-check"></i> @post.CreatedAt.ToString("dd MMMM yyyy")
                        </span>
                        <span class="read-time"><i class="fa-regular fa-clock"></i> ~@post.ReadTime мин.</span>
                    </div>

                    <h1 class="post-main-title">@post.Title</h1>
                    <p class="post-lead">@post.ShortDescription</p>
                </div>

                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <div class="post-featured-image">
                        <img src="@post.CoverImageUrl" alt="@post.Title" />
                    </div>
                }
                <div id="mobile-toc-container" class="mobile-toc fade-up" style="display: none;">
                    <details class="mobile-toc-details" id="mobile-toc-details">
                        <summary class="mobile-toc-summary">
                            <i class="fa-solid fa-list-ul"></i> Содержание статьи
                        </summary>
                        <ul id="mobile-toc-list" class="toc-list" style="margin-top: 15px;"></ul>
                    </details>
                </div>
                <div class="article-content" id="article-content">
                    @((MarkupString)post.Content)
                </div>


@if (post.QuizId.HasValue && post.Quiz != null)
{
    var quizQuestions = JsonSerializer.Deserialize<List<QuizQuestion>>(post.Quiz.QuestionsJson) ?? new();
    var quizResults = JsonSerializer.Deserialize<List<QuizResult>>(post.Quiz.ResultsJson) ?? new();
    
    <div class="mt-5">
        <SpeechQuiz QuizData="@(new QuizModel { 
            Title = post.Quiz.Title, 
            Subtitle = post.Quiz.Subtitle, 
            Questions = quizQuestions 
        })" 
        ResultVariants="@quizResults"
        @rendermode="InteractiveServer" />
    </div>
}
@if (post.FlashcardSetId.HasValue && post.FlashcardSet != null)
{
    var cards = JsonSerializer.Deserialize<List<FlashcardModel>>(post.FlashcardSet.CardsJson);
    <Flashcards Cards="@cards" @rendermode="InteractiveServer" />
}

                @if (!string.IsNullOrEmpty(post.MainVideoUrl))
                {
                    <div class="media-container video-block fade-up">
                        <h3 class="media-title"><i class="fa-solid fa-circle-play"></i> Видео к статье</h3>
                        <div class="video-wrapper">
                            <video controls preload="metadata">
                                <source src="@post.MainVideoUrl" type="video/mp4">
                                Ваш браузер не поддерживает видео.
                            </video>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(post.MainAudioUrl))
                {
                    <div class="media-container audio-block fade-up">
                        <div class="audio-info">
                            <i class="fa-solid fa-headphones-simple audio-icon"></i>
                            <div>
                                <h4 style="margin: 0;">Аудиопример</h4>
                                <p style="margin: 0; font-size: 0.85rem; color: var(--text-secondary);">Послушайте правильное звучание</p>
                            </div>
                        </div>
                        <audio controls preload="metadata" class="custom-audio">
                            <source src="@post.MainAudioUrl" type="audio/mpeg">
                            Ваш браузер не поддерживает аудио.
                        </audio>
                    </div>
                }

                @if (!string.IsNullOrEmpty(post.FileAttachmentUrl))
                {
                    <div class="pdf-download-card fade-up">
                        <div class="pdf-icon">
                            <i class="fa-solid fa-file-pdf"></i>
                        </div>
                        <div class="pdf-info">
                            <h4>Бонус к статье</h4>
                            <p>@(string.IsNullOrEmpty(post.FileAttachmentName) ? "Полезный материал для скачивания" : post.FileAttachmentName)</p>
                        </div>
                        <a href="@post.FileAttachmentUrl" download="@post.FileAttachmentName" class="pdf-btn">
                            <i class="fa-solid fa-cloud-arrow-down"></i> Скачать PDF
                        </a>
                    </div>
                }

                <div class="post-footer">
                    <div class="share-box">
                        <span>Понравилась статья? Поделитесь с друзьями:</span>
                        <div class="share-links">
                            <a href="https://t.me/share/url?url=@NavManager.Uri&text=@post.Title" target="_blank" class="share-btn tg"><i class="fa-brands fa-telegram"></i></a>
                            <a href="https://vk.com/share.php?url=@NavManager.Uri" target="_blank" class="share-btn vk"><i class="fa-brands fa-vk"></i></a>
                            <a href="https://api.whatsapp.com/send?text=@post.Title %0A @NavManager.Uri" target="_blank" class="share-btn wa"><i class="fa-brands fa-whatsapp"></i></a>
                        </div>
                    </div>
                </div>

            </div>

           
            <aside class="post-sidebar">
                <div class="toc-container fade-up" id="toc-container" style="display: none;">
                    <h4 class="toc-title"><i class="fa-solid fa-list-ul"></i> Содержание</h4>
                    <ul id="toc-list" class="toc-list"></ul>
                </div>
            </aside>

        </div>
        <script>
            setTimeout(function() {
                if (typeof window.buildToc === 'function') {
                    window.buildToc();
                } else {
                    console.log("Функция buildToc еще не загрузилась");
                }
            }, 150);
        </script>
    </div>
}

<style>
    .mobile-toc { display: none; }

    @@media (max-width: 1023px) { 
        .post-wrapper { padding-top: 100px; }
        .post-main-title { font-size: 2.2rem; }
        .post-lead { font-size: 1.1rem; }
        .audio-block { flex-direction: column; border-radius: 20px; text-align: center; }
        .custom-audio { width: 100%; }
        .pdf-download-card { flex-direction: column; text-align: center; }
        .pdf-btn { width: 100%; justify-content: center; }
        
        .mobile-toc { display: block; margin-bottom: 40px; }
        .mobile-toc-details {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid var(--accent-light);
            box-shadow: var(--shadow-sm);
        }
        .mobile-toc-summary {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary-color);
            cursor: pointer;
            outline: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .mobile-toc-details[open] .mobile-toc-summary {
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--accent-light);
        }
    }
    .post-layout {
        display: flex;
        gap: 40px;
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .post-main {
        flex: 1;
        max-width: 800px;
    }
    
    .post-sidebar {
        width: 320px;
        display: none;
    }
    
    @@media (min-width: 1024px) {
        .post-sidebar { display: block; }
    }

    .toc-container {
        position: sticky;
        top: 100px; 
        background: var(--card-bg);
        padding: 25px;
        border-radius: 20px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--accent-light);
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }
    
    .toc-title { margin-bottom: 20px; font-size: 1.1rem; color: var(--primary-color); font-weight: 800;}
    
    .toc-list { list-style: none; padding: 0; margin: 0; }
    .toc-item { margin-bottom: 12px; }
    
    .toc-h1 { font-weight: 700; font-size: 1rem; margin-top: 10px; }
    .toc-h2 { font-weight: 600; font-size: 0.95rem; padding-left: 10px; }
    .toc-h3 { padding-left: 20px; font-size: 0.9rem; }

    .toc-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: 0.3s;
        display: block;
        line-height: 1.4;
    }
    .toc-link:hover { color: var(--primary-color); transform: translateX(5px); }

    .post-wrapper {
        padding: 120px 20px 80px;
        background-color: var(--bg-color);
        min-height: 100vh;
    }

    .post-nav { margin-bottom: 40px; }
    .back-link { text-decoration: none; color: var(--text-secondary); font-weight: 600; transition: var(--transition); display: flex; align-items: center; gap: 10px; }
    .back-link:hover { color: var(--primary-color); transform: translateX(-5px); }

    .post-meta-top { display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 20px; align-items: center; }
    .post-tag { background: var(--accent-light); color: var(--primary-color); padding: 4px 12px; border-radius: 50px; font-weight: 700; font-size: 0.85rem; }
    .post-date, .read-time { color: var(--text-secondary); font-size: 0.9rem; display: flex; align-items: center; gap: 6px; }

    .post-main-title { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.2; margin-bottom: 20px; color: var(--text-color); }
    .post-lead { font-size: 1.25rem; color: var(--text-secondary); line-height: 1.6; border-left: 4px solid var(--primary-color); padding-left: 20px; margin-bottom: 40px; }

    .post-featured-image { margin-bottom: 50px; border-radius: 25px; overflow: hidden; box-shadow: var(--shadow-md); }
    .post-featured-image img { width: 100%; height: auto; display: block; }

    .post-body, .article-content { font-size: 1.15rem; line-height: 1.85; color: var(--text-color); }
    .article-content h1, .article-content h2, .article-content h3 { margin: 40px 0 20px; color: var(--text-color); }
    .article-content p { margin-bottom: 25px; }
    .article-content img { max-width: 100%; border-radius: 15px; margin: 30px 0; box-shadow: var(--shadow-sm); }

    .media-container { margin: 40px 0; }
    .media-title { font-size: 1.4rem; color: var(--text-color); margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }

    .video-wrapper { border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md); background: #000; line-height: 0; }
    .video-wrapper video { width: 100%; max-height: 600px; object-fit: cover; }

    .audio-block { display: flex; align-items: center; gap: 20px; background: var(--bg-secondary); padding: 20px 30px; border-radius: 50px; border: 1px solid var(--accent-light); }
    .audio-icon { font-size: 2.5rem; color: var(--primary-color); }
    .audio-info { display: flex; align-items: center; gap: 15px; min-width: 200px; }
    .custom-audio { flex-grow: 1; height: 40px; outline: none; }

    .pdf-download-card { display: flex; align-items: center; gap: 20px; background: var(--accent-light); padding: 25px; border-radius: 20px; margin-top: 40px; border: 2px dashed var(--primary-color); }
    .pdf-icon { font-size: 3rem; color: #ff4d4d; background: white; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; border-radius: 15px; box-shadow: var(--shadow-sm); }
    .pdf-info { flex-grow: 1; }
    .pdf-info h4 { margin: 0 0 5px 0; color: var(--text-color); }
    .pdf-info p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); }
    .pdf-btn { background: var(--primary-color); color: white !important; text-decoration: none; padding: 12px 25px; border-radius: 50px; font-weight: 700; display: flex; align-items: center; gap: 10px; transition: var(--transition); box-shadow: 0 4px 15px rgba(27, 84, 245, 0.2); }
    .pdf-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(27, 84, 245, 0.3); }

    .post-footer { margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--accent-light); }
    .share-box { text-align: center; }
    .share-links { display: flex; justify-content: center; gap: 15px; margin-top: 20px; }
    .share-btn { width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; text-decoration: none; font-size: 1.2rem; transition: var(--transition); }
    .share-btn:hover { transform: translateY(-3px); filter: brightness(1.1); }
    .tg { background: #0088cc; }
    .vk { background: #4a76a8; }
    .wa { background: #25d366; }

    .loader-container { padding: 150px 20px; text-align: center; }
    .spinner { width: 40px; height: 40px; border: 4px solid var(--accent-light); border-top: 4px solid var(--primary-color); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px; }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    @@media (max-width: 768px) {
        .post-wrapper { padding-top: 100px; }
        .post-main-title { font-size: 2.2rem; }
        .post-lead { font-size: 1.1rem; }
        .audio-block { flex-direction: column; border-radius: 20px; text-align: center; }
        .custom-audio { width: 100%; }
        .pdf-download-card { flex-direction: column; text-align: center; }
        .pdf-btn { width: 100%; justify-content: center; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Slug { get; set; }
    
    private BlogPost? post;

    protected override async Task OnInitializedAsync()
    {
        post = await BlogService.GetPostByIdAsync(Id);
        if (post == null || post.IsDraft) NavManager.NavigateTo("/blog");
    }



    private string GetAbsoluteImageUrl(string? relativeUrl)
    {
        string path = string.IsNullOrEmpty(relativeUrl) ? "/img/default-blog.jpg" : relativeUrl;
        if (path.StartsWith("http")) return path;
        return $"{NavManager.BaseUri.TrimEnd('/')}{path}";
    }
}