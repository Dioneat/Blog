@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavManager

<PageTitle>Вход в систему | Логопед-педагог</PageTitle>

<div class="login-page">
    <div class="login-card">
        <h1 class="login-title">Вход в кабинет</h1>

        @if (showError)
        {
            <div class="login-error" role="alert">
                Неверный логин или пароль
            </div>
        }

        <form action="/api/auth/login" method="post" class="login-form">
            <AntiforgeryToken />

            <div class="login-field">
                <label for="username">Логин</label>
                <input id="username" type="text" name="username" autocomplete="username" required autofocus />
            </div>

            <div class="login-field">
                <label for="password">Пароль</label>
                <input id="password" type="password" name="password" autocomplete="current-password" required />
            </div>

            <button type="submit" class="cta-btn login-submit">
                Войти
            </button>
        </form>
    </div>
</div>

@code {
    private bool showError;

    protected override void OnInitialized()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);

        if (QueryHelpers.ParseQuery(uri.Query).ContainsKey("error"))
        {
            showError = true;
        }
    }
}