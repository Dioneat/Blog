@using Blog10.Models

<div class="quiz-container fade-up">
    @if (QuizData != null && QuizData.Questions != null && QuizData.Questions.Any())
    {
        @if (!quizCompleted)
        {
            <div class="quiz-header">
                <span class="quiz-progress">Вопрос @(currentQuestionIndex + 1) из @QuizData.Questions.Count</span>
                <h3 class="quiz-question">@QuizData.Questions[currentQuestionIndex].Text</h3>
            </div>

            <div class="quiz-options">
                @foreach (var option in QuizData.Questions[currentQuestionIndex].Answers)
                {
                    <button class="quiz-btn" @onclick="() => SelectOption(option.Score)">
                        @option.Text
                    </button>
                }
            </div>
        }
        else
        {
            <div class="quiz-result fade-up">
                <div class="result-icon">
                    <i class="fa-solid fa-ranking-star"></i>
                </div>
                <h2>Тест завершен!</h2>
                <h3 style="color: var(--primary-color); margin-bottom: 20px;">Ваш балл: @totalScore</h3>
                
                <p class="result-text">@GetResultMessage()</p>
                
                <div class="result-actions">
                    <a href="/#contacts" class="cta-btn">Записаться на консультацию</a>
                    <button class="cta-btn outline" @onclick="ResetQuiz">Пройти заново</button>
                </div>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 30px; color: var(--text-secondary);">
            <i class="fa-solid fa-circle-exclamation" style="font-size: 2rem; margin-bottom: 10px;"></i>
            <p>Тест находится в стадии разработки.</p>
        </div>
    }
</div>

<style>
    .quiz-container {
        background: var(--card-bg, #ffffff);
        padding: 40px;
        border-radius: 25px;
        box-shadow: var(--shadow-md, 0 10px 30px rgba(0,0,0,0.05));
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
        border: 1px solid var(--accent-light, #eef2fa);
    }

    .quiz-progress {
        display: inline-block;
        background: var(--accent-light, #eef2fa);
        color: var(--primary-color, #1b54f5);
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }

    .quiz-question {
        font-size: 1.5rem;
        color: var(--text-color, #2d3436);
        margin-bottom: 30px;
        line-height: 1.4;
    }

    .quiz-options {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .quiz-btn {
        background: var(--bg-secondary, #f8f9fa);
        color: var(--text-color, #2d3436);
        border: 2px solid transparent;
        padding: 15px 20px;
        border-radius: 15px;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: left;
    }

        .quiz-btn:hover {
            background: var(--card-bg, #ffffff);
            border-color: var(--primary-color, #1b54f5);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm, 0 5px 15px rgba(0,0,0,0.05));
        }

    .result-icon i {
        font-size: 4rem;
        color: #f1c40f;
        margin-bottom: 20px;
    }

    .result-text {
        font-size: 1.15rem;
        color: var(--text-secondary, #636e72);
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .result-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cta-btn {
        background: var(--primary-color, #1b54f5);
        color: white !important;
        text-decoration: none;
        padding: 12px 25px;
        border-radius: 50px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(27, 84, 245, 0.3);
        }

        .cta-btn.outline {
            background: transparent;
            border: 2px solid var(--primary-color, #1b54f5);
            color: var(--primary-color, #1b54f5) !important;
            box-shadow: none;
        }

            .cta-btn.outline:hover {
                background: var(--primary-color, #1b54f5);
                color: white !important;
            }
</style>

@code {
    [Parameter]
    public QuizModel? QuizData { get; set; }
    
    [Parameter]
    public List<QuizResult> ResultVariants { get; set; } = new();

    private int currentQuestionIndex = 0;
    private int totalScore = 0;
    private bool quizCompleted = false;

    private void SelectOption(int score)
    {
        totalScore += score;
        currentQuestionIndex++;

        if (QuizData != null && QuizData.Questions != null && currentQuestionIndex >= QuizData.Questions.Count)
        {
            quizCompleted = true;
        }
    }

    private string GetResultMessage()
    {
        if (ResultVariants == null || !ResultVariants.Any())
        {
            return "Спасибо за прохождение теста! Свяжитесь со мной для подробной расшифровки результатов.";
        }

        var result = ResultVariants.FirstOrDefault(r => totalScore >= r.MinScore && totalScore <= r.MaxScore);
        
        if (result != null && !string.IsNullOrWhiteSpace(result.Message))
        {
            return result.Message;
        }

        return "Спасибо за прохождение теста!";
    }

    private void ResetQuiz()
    {
        currentQuestionIndex = 0;
        totalScore = 0;
        quizCompleted = false;
    }
}