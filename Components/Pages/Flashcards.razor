@using Blog10.Models

<div class="flashcards-grid">
    @if (Cards != null && Cards.Any())
    {
        @foreach (var card in Cards)
        {
            <div class="flashcard @(card.IsFlipped ? "flipped" : "")" @onclick="() => FlipCard(card)">
                <div class="flashcard-inner">
                    
                    <div class="flashcard-front">
                        <div class="card-icon">
                            <i class="@card.IconClass"></i>
                        </div>
                        <h3>@card.FrontTitle</h3>
                        <p class="click-hint"><i class="fa-solid fa-hand-pointer"></i> Нажми, чтобы перевернуть</p>
                    </div>

                    <div class="flashcard-back">
                        <h4>@card.BackTitle</h4>
                        <p>@card.BackDescription</p>
                    </div>

                </div>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 20px; color: var(--text-secondary); width: 100%;">
            Карточки пока не добавлены.
        </div>
    }
</div>

<style>
    .flashcards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        padding: 20px 0;
    }

    .flashcard {
        background-color: transparent;
        height: 300px;
        perspective: 1000px; 
        cursor: pointer;
    }

    .flashcard-inner {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform 0.6s;
        transform-style: preserve-3d; 
    }

    .flashcard.flipped .flashcard-inner {
        transform: rotateY(180deg);
    }

    .flashcard-front, .flashcard-back {
        position: absolute;
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden; 
        backface-visibility: hidden;
        border-radius: 20px;
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: var(--shadow-md, 0 4px 15px rgba(0,0,0,0.1));
    }

    .flashcard-front {
        background-color: var(--card-bg, white);
        border: 2px solid var(--accent-light, #eef2fa);
    }

    .card-icon {
        font-size: 4rem;
        color: var(--primary-color, #1b54f5);
        margin-bottom: 20px;
    }

    .flashcard-front h3 {
        color: var(--text-color, #333);
        margin-bottom: 15px;
    }

    .click-hint {
        font-size: 0.85rem;
        color: var(--text-secondary, #666);
        opacity: 0.7;
    }

    .flashcard-back {
        background-color: var(--primary-color, #1b54f5);
        color: white;
        transform: rotateY(180deg); 
    }

        .flashcard-back h4 {
            font-size: 1.3rem;
            margin-bottom: 15px;
        }

        .flashcard-back p {
            font-size: 1rem;
            line-height: 1.5;
            opacity: 0.9;
        }
</style>

@code {
    [Parameter]
    public List<FlashcardModel> Cards { get; set; } = new();

    private void FlipCard(FlashcardModel card)
    {
        card.IsFlipped = !card.IsFlipped;
    }
}