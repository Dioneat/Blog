@page "/search"
@rendermode InteractiveServer

@using Blog10.Models
@using Blog10.Services
@using Radzen
@using Radzen.Blazor

@inject IBlogService BlogService
@inject NavigationManager NavManager

<PageTitle>Поиск по сайту | Логопед-педагог</PageTitle>

<section class="section search-section">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Поиск по материалам</h1>
            <p class="section-subtitle">Найдите нужные статьи, упражнения и советы</p>
        </div>

        <div class="row">
            <div class="col-12 col-lg-3 mb-5">
                <div class="search-filters-card">
                    <h3 class="filters-title"><i class="fa-solid fa-sliders"></i> Фильтры</h3>

                    <RadzenStack Gap="1.5rem">
                        <RadzenFormField Text="Что ищем?" style="width: 100%;">
                            <RadzenTextBox @bind-Value="searchQuery" Placeholder="Например: звук Р..." />
                        </RadzenFormField>

                        <RadzenFormField Text="Категории (Теги)" style="width: 100%;">
                            <RadzenDropDown @bind-Value="selectedTags" Data="@availableTags" Multiple="true" AllowClear="true" Chips="true" Placeholder="Все категории" />
                        </RadzenFormField>

                        <div class="date-filters">
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-1">Период публикации:</RadzenText>
                            <RadzenDatePicker @bind-Value="dateFrom" DateFormat="dd.MM.yyyy" Placeholder="С даты" style="width: 100%; margin-bottom: 10px;" />
                            <RadzenDatePicker @bind-Value="dateTo" DateFormat="dd.MM.yyyy" Placeholder="По дату" style="width: 100%;" />
                        </div>

                        <RadzenFormField Text="Сортировка" style="width: 100%;">
                            <RadzenDropDown @bind-Value="sortOrder" Data="@sortOptions" ValueProperty="Value" TextProperty="Text" />
                        </RadzenFormField>

                        <RadzenButton Text="Найти материалы" Icon="search" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Click="ExecuteSearch" style="width: 100%; border-radius: 20px;" />
                        
                        @if(IsFilterActive())
                        {
                            <RadzenButton Text="Сбросить всё" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger" Click="ResetFilters" style="width: 100%;" />
                        }
                    </RadzenStack>
                </div>
            </div>

            <div class="col-12 col-lg-9">
                <div class="search-results-header">
                    <span>Найдено статей: <strong>@posts.Count</strong></span>
                </div>

                @if (isLoading)
                {
                    <div style="text-align: center; padding: 50px;">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 3rem; color: var(--primary-color);"></i>
                    </div>
                }
                else if (!posts.Any())
                {
                    <div class="empty-state">
                        <i class="fa-regular fa-face-frown-open"></i>
                        <h3>Ничего не найдено</h3>
                        <p>Попробуйте изменить параметры поиска или выбрать другие категории.</p>
                    </div>
                }
                else
                {
                    <div class="grid-2-search">
                        @foreach (var post in posts)
                        {
                            <div class="card blog-card">
                                <div class="blog-thumb" style="height: 200px;">
                                    @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                                    {
                                        <img src="@post.CoverImageUrl" alt="@post.Title">
                                    }
                                    else
                                    {
                                        <div class="blog-placeholder">
                                            <i class="fa-solid fa-shapes placeholder-icon"></i>
                                            <span class="placeholder-text">Статья</span>
                                        </div>
                                    }
                                </div>
                                <div class="blog-content" style="padding: 20px;">
                                    <div class="blog-meta" style="margin-bottom: 10px; font-size: 0.8rem;">
                                        <span><i class="fa-regular fa-calendar"></i> @post.CreatedAt.ToString("dd.MM.yyyy")</span>
                                        <span><i class="fa-regular fa-clock"></i> ~@post.ReadTime мин.</span>
                                    </div>
                                    <h3 style="font-size: 1.2rem; margin-bottom: 10px;">@post.Title</h3>
                                    <p style="font-size: 0.9rem; margin-bottom: 15px;">@(post.ShortDescription.Length > 80 ? post.ShortDescription.Substring(0, 80) + "..." : post.ShortDescription)</p>
                                    <a href="@GetArticleUrl(post)" class="blog-link" style="font-size: 0.9rem;">Читать <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    .search-section { padding-top: 120px; min-height: 100vh; background-color: var(--bg-secondary); }
    
    .search-filters-card {
        background: var(--card-bg);
        padding: 30px 20px;
        border-radius: 25px;
        box-shadow: var(--shadow-sm);
        position: sticky;
        top: 100px;
    }
    
    .filters-title { font-size: 1.3rem; margin-bottom: 25px; color: var(--primary-color); font-weight: 800; display: flex; align-items: center; gap: 10px; }
    
    .search-results-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 30px; padding-bottom: 15px; border-bottom: 2px solid var(--accent-light);
        font-size: 1.1rem; color: var(--text-secondary);
    }

    .grid-2-search { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }

    .empty-state { text-align: center; padding: 60px 20px; background: var(--card-bg); border-radius: 25px; box-shadow: var(--shadow-sm); }
    .empty-state i { font-size: 4rem; color: var(--text-secondary); opacity: 0.5; margin-bottom: 20px; }
    .empty-state h3 { color: var(--text-color); margin-bottom: 10px; }

    .blog-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--primary-color), #8CA8FF); display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; position: absolute; top: 0; left: 0; }
    .placeholder-icon { font-size: 2.5rem; opacity: 0.8; margin-bottom: 10px; }
    .placeholder-text { font-weight: 800; letter-spacing: 1px; text-transform: uppercase; font-size: 0.7rem; background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 20px; }
</style>

@code {
    [SupplyParameterFromQuery] public string? Q { get; set; }

    private List<BlogPost> posts = new();
    private List<string> availableTags = new();
    private bool isLoading = true;

    private string? searchQuery;
    private IEnumerable<string>? selectedTags;
    private DateTime? dateFrom;
    private DateTime? dateTo;
    private string sortOrder = "newest";

    private List<dynamic> sortOptions = new List<dynamic>
    {
        new { Text = "Сначала новые", Value = "newest" },
        new { Text = "Сначала старые", Value = "oldest" }
    };

    protected override async Task OnInitializedAsync()
    {
        availableTags = await BlogService.GetAllTagsAsync();
        searchQuery = Q; 
        await ExecuteSearch();
    }

    private async Task ExecuteSearch()
    {
        isLoading = true;
        posts = await BlogService.SearchPostsAsync(searchQuery, selectedTags, dateFrom, dateTo, sortOrder);
        isLoading = false;
    }

    private async Task ResetFilters()
    {
        searchQuery = null;
        selectedTags = null;
        dateFrom = null;
        dateTo = null;
        sortOrder = "newest";
        await ExecuteSearch();
    }

    private bool IsFilterActive()
    {
        return !string.IsNullOrEmpty(searchQuery) || 
               (selectedTags != null && selectedTags.Any()) || 
               dateFrom.HasValue || 
               dateTo.HasValue || 
               sortOrder != "newest";
    }

    private string GetArticleUrl(BlogPost post)
    {
        return string.IsNullOrWhiteSpace(post.Slug) ? $"/blog/{post.Id}" : $"/blog/{post.Id}/{post.Slug}";
    }
}