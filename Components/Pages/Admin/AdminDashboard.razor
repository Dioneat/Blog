@page "/admin"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Blog10.Data
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject AppDbContext DbContext

<PageTitle>Дашборд | Админ-панель</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4" style="color: var(--secondary-color);">
    Добро пожаловать в панель управления!
</RadzenText>

<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">
    Здесь вы можете управлять контентом вашего сайта. Выберите нужный раздел в меню слева или используйте быстрые ссылки ниже.
</RadzenText>

<RadzenRow Gap="1.5rem" class="rz-mb-4">
    
    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard style="text-align: center; padding: 30px; border-top: 5px solid var(--primary-color);">
            <RadzenIcon Icon="article" style="font-size: 3rem; color: var(--primary-color); margin-bottom: 15px;" />
            <RadzenText TextStyle="TextStyle.H6" style="color: var(--text-secondary);">Всего статей</RadzenText>
            <RadzenText TextStyle="TextStyle.H2" style="font-weight: bold; color: var(--secondary-color);">@articlesCount</RadzenText>
            <RadzenButton Text="Управление статьями" ButtonStyle="ButtonStyle.Light" class="rz-mt-2" style="width: 100%;" Click="@(() => NavManager.NavigateTo("/admin/articles"))" />
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard style="text-align: center; padding: 30px; border-top: 5px solid #4caf50;">
            <RadzenIcon Icon="reviews" style="font-size: 3rem; color: #4caf50; margin-bottom: 15px;" />
            <RadzenText TextStyle="TextStyle.H6" style="color: var(--text-secondary);">Отзывов</RadzenText>
            <RadzenText TextStyle="TextStyle.H2" style="font-weight: bold; color: var(--secondary-color);">@reviewsCount</RadzenText>
            <RadzenButton Text="Смотреть отзывы" ButtonStyle="ButtonStyle.Light" class="rz-mt-2" style="width: 100%;" Click="@(() => NavManager.NavigateTo("/admin/reviews"))" />
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard style="text-align: center; padding: 30px; border-top: 5px solid #ff9800;">
            <RadzenIcon Icon="label" style="font-size: 3rem; color: #ff9800; margin-bottom: 15px;" />
            <RadzenText TextStyle="TextStyle.H6" style="color: var(--text-secondary);">Категорий</RadzenText>
            <RadzenText TextStyle="TextStyle.H2" style="font-weight: bold; color: var(--secondary-color);">@categoriesCount</RadzenText>
            <RadzenButton Text="Редактировать" ButtonStyle="ButtonStyle.Light" class="rz-mt-2" style="width: 100%;" Click="@(() => NavManager.NavigateTo("/admin/categories"))" />
        </RadzenCard>
    </RadzenColumn>

</RadzenRow>

@code {
    [Inject]
    public NavigationManager NavManager { get; set; } = default!;

    private int articlesCount = 0;
    private int reviewsCount = 0;
    private int categoriesCount = 0;

    protected override async Task OnInitializedAsync()
    {
        articlesCount = await DbContext.Articles.CountAsync();
        reviewsCount = await DbContext.Reviews.CountAsync();
        categoriesCount = await DbContext.Categories.CountAsync();
    }
}