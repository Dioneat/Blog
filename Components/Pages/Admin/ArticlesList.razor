@page "/admin/articles"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using System.Text.RegularExpressions
@using Microsoft.EntityFrameworkCore
@using Blog10.Data
@using Blog10.Models
@using Radzen
@using Radzen.Blazor

@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject DialogService DialogService
@inject Blog10.Services.FileService FileService

<PageTitle>Управление статьями</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center rz-mb-4" style="gap: 15px;">
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Статьи блога</RadzenText>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
        <RadzenButton Text="Импорт из ВК" Icon="cloud_download" ButtonStyle="ButtonStyle.Secondary"
                      Click="@(() => NavManager.NavigateTo("/admin/articles/vk-sync"))"
                      class="rz-flex-1 rz-flex-md-0" />
                      
        <RadzenButton Text="Написать статью" Icon="add_circle" ButtonStyle="ButtonStyle.Primary"
                      Click="@GoToCreate"
                      class="rz-flex-1 rz-flex-md-0" />
    </RadzenStack>
</div>

<RadzenDataGrid @ref="articlesGrid" Data="@articles" TItem="BlogPost" AllowPaging="true" PageSize="10" AllowSorting="true" AllowFiltering="true">
    <Columns>
        <RadzenDataGridColumn TItem="BlogPost" Property="Id" Title="ID" Width="60px" TextAlign="TextAlign.Center" />
        
        <RadzenDataGridColumn TItem="BlogPost" Property="Title" Title="Заголовок">
            <Template Context="post">
                <strong>@post.Title</strong>
            </Template>
        </RadzenDataGridColumn>
        
        <RadzenDataGridColumn TItem="BlogPost" Property="CreatedAt" Title="Дата" Width="150px">
            <Template Context="post">
                @post.CreatedAt.ToString("dd.MM.yyyy")
            </Template>
        </RadzenDataGridColumn>
        
        <RadzenDataGridColumn TItem="BlogPost" Property="IsDraft" Title="Статус" Width="120px" TextAlign="TextAlign.Center">
            <Template Context="post">
                @if (post.IsDraft)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Черновик" />
                }
                else
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Опубликована" />
                }
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="BlogPost" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="120px">
            <Template Context="post">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" Wrap="FlexWrap.NoWrap">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium"
                                  Click="@(() => EditPost(post.Id))" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium"
                                  Click="@(() => DeletePost(post))" />
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private List<BlogPost> articles = new List<BlogPost>();
    private RadzenDataGrid<BlogPost>? articlesGrid;

    protected override async Task OnInitializedAsync()
    {
        articles = await DbContext.Articles.AsNoTracking().OrderByDescending(a => a.CreatedAt).ToListAsync();
    }

    private void GoToCreate() => NavManager.NavigateTo("/admin/articles/create");
    private void EditPost(int id) => NavManager.NavigateTo($"/admin/articles/edit/{id}");

    private async Task DeletePost(BlogPost post)
    {
        var result = await DialogService.Confirm(
            $"Вы действительно хотите навсегда удалить статью \"{post.Title}\"? Все прикрепленные файлы также будут удалены.",
            "Подтверждение удаления",
            new ConfirmOptions() { OkButtonText = "Да, удалить", CancelButtonText = "Отмена" });

        if (result == true)
        {
            // Очистка физических файлов
            FileService.DeleteFile(post.CoverImageUrl);
            FileService.DeleteFile(post.MainAudioUrl);
            FileService.DeleteFile(post.MainVideoUrl);
            FileService.DeleteFile(post.FileAttachmentUrl);

            // Очистка картинок внутри текста статьи
            if (!string.IsNullOrEmpty(post.Content))
            {
                var matches = Regex.Matches(post.Content, @"src=""(/uploads/images/[^""]+)""");
                foreach (Match match in matches)
                {
                    if (match.Groups.Count > 1)
                    {
                        FileService.DeleteFile(match.Groups[1].Value);
                    }
                }
            }

            // ОПТИМИЗАЦИЯ: Прямое удаление из БД без загрузки в память
            await DbContext.Articles.Where(a => a.Id == post.Id).ExecuteDeleteAsync();
            
            articles.RemoveAll(a => a.Id == post.Id);
            if (articlesGrid != null) await articlesGrid.Reload();
            
            FileService.RunGarbageCollectorInBackground();
        }
    }
}