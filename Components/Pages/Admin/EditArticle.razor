@page "/admin/articles/edit/{Id:int}"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@implements IDisposable
@using System.Text.Json
@using System.Timers

@using Blog10.Utils

@inject NotificationService Notification
@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject Blog10.Services.FileService FileService

<PageTitle>Редактирование статьи</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Click="@(() => NavManager.NavigateTo("/admin/articles"))" />
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Редактирование статьи</RadzenText>
</RadzenStack>

@if (editPost == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="BlogPost" Data="@editPost" Submit="OnSubmit">
        <RadzenStack Gap="1.5rem">
            
            @* --- 1. ОСНОВНАЯ ИНФОРМАЦИЯ --- *@
            <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-primary);">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-pen-nib rz-mr-2"></i> Основная информация</RadzenText>
                
                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="Заголовок статьи" style="width: 100%;">
                        <RadzenTextBox @bind-Value="editPost.Title" Name="Title" />
                        <RadzenRequiredValidator Component="Title" Text="Заголовок обязателен" />
                    </RadzenFormField>

                    <RadzenFormField Text="Краткое описание" style="width: 100%;">
                        <RadzenTextArea @bind-Value="editPost.ShortDescription" Rows="3" />
                    </RadzenFormField>

                    <div class="row">
                        <div class="col-12 col-md-6 rz-mb-3 rz-mb-md-0">
                            <RadzenFormField Text="Категории статьи" style="width: 100%;">
                                <RadzenDropDown @bind-Value="editPost.Tags" Data="@availableTags" Multiple="true" AllowClear="true" Placeholder="Выберите категории..." Chips="true" />
                            </RadzenFormField>
                        </div>
                        <div class="col-12 col-md-6">
                            <RadzenFormField Text="Дата и время публикации" style="width: 100%;">
                                <RadzenDatePicker @bind-Value="editPost.CreatedAt" ShowTime="true" ShowSeconds="false" DateFormat="dd.MM.yyyy HH:mm" />
                            </RadzenFormField>
                        </div>
                    </div>
                </RadzenStack>
            </RadzenCard>

            @* --- 2. МЕДИА И ФАЙЛЫ --- *@
            <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-info);">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-photo-film rz-mr-2"></i> Медиа и файлы</RadzenText>
                
                <div class="row">
                    <div class="col-12 col-lg-6 rz-mb-4">
                        <RadzenStack Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Subtitle2">Титульное изображение (Обложка)</RadzenText>
                            <RadzenUpload Url="api/upload/image" Accept="image/*" Complete="OnUploadComplete" style="width: 100%;" ChooseText="Выбрать обложку..." />
                            @if (!string.IsNullOrEmpty(editPost.CoverImageUrl))
                            {
                                <div style="margin-top: 10px;">
                                    <img src="@editPost.CoverImageUrl" alt="Предпросмотр обложки" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; border: 1px solid var(--rz-secondary-light);" />
                                </div>
                            }
                        </RadzenStack>
                    </div>
                    
                    <div class="col-12 col-lg-6">
                        <RadzenStack Gap="1rem">
                            <div class="rz-p-3 rz-background-color-warning-lighter rz-border-radius-2">
                                <RadzenText TextStyle="TextStyle.Subtitle2">Аудио-вставка</RadzenText>
                                <RadzenUpload Url="api/upload/audio" Accept="audio/*" Complete=@OnAudioUploadComplete ChooseText="Загрузить Аудио" style="width: 100%;" />
                                @if (!string.IsNullOrEmpty(editPost.MainAudioUrl))
                                {
                                    <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                                        <audio controls src="@editPost.MainAudioUrl" style="height: 30px; width: 80%;"></audio>
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="RemoveAudio" title="Открепить" />
                                    </div>
                                }
                            </div>

                            <div class="rz-p-3 rz-background-color-success-lighter rz-border-radius-2">
                                <RadzenText TextStyle="TextStyle.Subtitle2">Видео-вставка</RadzenText>
                                <RadzenUpload Url="api/upload/video" Accept="video/*" Complete=@OnVideoUploadComplete ChooseText="Загрузить Видео" style="width: 100%;" />
                                @if (!string.IsNullOrEmpty(editPost.MainVideoUrl))
                                {
                                    <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                                        <span style="color: var(--rz-success-dark);"><i class="fa-solid fa-video rz-mr-2"></i> Видео прикреплено</span>
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="RemoveVideo" title="Открепить" />
                                    </div>
                                }
                            </div>
                        </RadzenStack>
                    </div>
                </div>

                <RadzenStack Gap="0.5rem" class="rz-mt-4 rz-p-3 rz-background-color-info-lighter rz-border-radius-2">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Полезный материал (PDF)</RadzenText>
                    <div class="row">
                        <div class="col-12 col-md-6 rz-mb-2 rz-mb-md-0">
                            <RadzenFormField Text="Название файла" style="width: 100%;">
                                <RadzenTextBox @bind-Value="editPost.FileAttachmentName" Placeholder="Например: Памятка по артикуляции" />
                            </RadzenFormField>
                        </div>
                        <div class="col-12 col-md-6">
                            <RadzenUpload Url="api/upload/document" Accept="application/pdf" Complete=@OnDocumentUploadComplete ChooseText="Выбрать PDF-файл" style="width: 100%; height: 40px;" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(editPost.FileAttachmentUrl))
                    {
                        <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                            <span style="color: var(--rz-info-dark);"><i class="fa-solid fa-file-pdf rz-mr-2"></i> @(string.IsNullOrEmpty(editPost.FileAttachmentName) ? "Документ прикреплен" : editPost.FileAttachmentName)</span>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                <a href="@editPost.FileAttachmentUrl" target="_blank" class="rz-button rz-button-sm rz-variant-flat rz-light"><i class="fa-solid fa-eye"></i></a>
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="RemoveDocument" title="Открепить файл" />
                            </RadzenStack>
                        </div>
                    }
                </RadzenStack>
            </RadzenCard>

            @* --- 3. ИНТЕРАКТИВЫ (ТЕСТЫ И КАРТОЧКИ) --- *@
            <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-warning);">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-gamepad rz-mr-2"></i> Интерактивы</RadzenText>
                
                <div class="row">
                    <div class="col-12 col-md-6 rz-mb-3 rz-mb-md-0">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить тест</RadzenText>
                        <RadzenDropDown TValue="int?" @bind-Value="editPost.QuizId"
                                        Data="@availableQuizzes" TextProperty="Title" ValueProperty="Id"
                                        Placeholder="Выберите тест из списка..." AllowClear="true" style="width: 100%;" />
                    </div>
                    <div class="col-12 col-md-6">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить карточки</RadzenText>
                        <RadzenDropDown TValue="int?" @bind-Value="editPost.FlashcardSetId"
                                        Data="@availableFlashcardSets" TextProperty="Name" ValueProperty="Id"
                                        Placeholder="Выберите набор карточек..." AllowClear="true" style="width: 100%;" />
                    </div>
                </div>
            </RadzenCard>

            @* --- 4. ТЕКСТ СТАТЬИ --- *@
            <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-success);">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-align-left rz-mr-2"></i> Текст статьи</RadzenText>
                
                <RadzenHtmlEditor @bind-Value="editPost.Content" style="height: 500px;" UploadUrl="api/upload/image">
                    <RadzenHtmlEditorUndo /><RadzenHtmlEditorRedo /><RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorBold /><RadzenHtmlEditorItalic /><RadzenHtmlEditorUnderline /><RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorAlignLeft /><RadzenHtmlEditorAlignCenter /><RadzenHtmlEditorAlignRight /><RadzenHtmlEditorSeparator />
                    <RadzenHtmlEditorFormatBlock /><RadzenHtmlEditorFontSize />
                    <RadzenHtmlEditorImage /><RadzenHtmlEditorLink /><RadzenHtmlEditorSource />
                </RadzenHtmlEditor>
            </RadzenCard>

            @* --- 5. ОБНОВЛЕНИЕ --- *@
            <div class="rz-p-4 rz-mt-2" style="background: var(--rz-secondary-lighter); border-radius: 12px; border: 1px solid var(--rz-secondary-light); box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
                    
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap" style="max-width: 100%;">
                        <RadzenButton ButtonType="ButtonType.Submit" Size="ButtonSize.Large" Icon="save" Text="Обновить статью" ButtonStyle="ButtonStyle.Success" />
                        
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-p-2 rz-px-3" style="background: white; border-radius: 8px; border: 2px solid var(--rz-warning); max-width: 100%;">
                            <RadzenSwitch @bind-Value="editPost.IsDraft" Name="IsDraft" />
                            <RadzenLabel Text="Скрыть (Черновик)" Component="IsDraft" style="margin-left: 10px; font-weight: 700; cursor: pointer; color: var(--text-color);" />
                        </RadzenStack>
                    </RadzenStack>

                    @if (lastSavedTime.HasValue)
                    {
                        <span style="color: var(--text-secondary); font-size: 0.95rem; font-weight: 600; white-space: nowrap;">
                            <i class="fa-solid fa-cloud-arrow-up" style="color: var(--rz-success);"></i> Сохранено: @lastSavedTime.Value.ToString("HH:mm:ss")
                        </span>
                    }
                </RadzenStack>
            </div>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter]
    public int Id { get; set; }
    
    private List<string> availableTags = new();
    private BlogPost? editPost;
    List<Quiz> availableQuizzes = new();
    List<FlashcardSet> availableFlashcardSets = new();
    
    private Timer? autoSaveTimer;
    private DateTime? lastSavedTime;
    private string StorageKey => $"article_draft_edit_{Id}";

    protected override async Task OnInitializedAsync()
    {
        availableTags = await DbContext.Categories.Select(c => c.Name).ToListAsync();
        editPost = await DbContext.Articles.FindAsync(Id);
        availableQuizzes = await DbContext.Quizzes.ToListAsync();
        availableFlashcardSets = await DbContext.FlashcardSets.ToListAsync();
        
        if (editPost == null) NavManager.NavigateTo("/admin/articles");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && editPost != null)
        {
            var savedDraftJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(savedDraftJson))
            {
                bool restore = await JSRuntime.InvokeAsync<bool>("confirm", "Найден несохраненный черновик этой статьи. Восстановить его?");
                if (restore)
                {
                    try
                    {
                        var draft = JsonSerializer.Deserialize<BlogPost>(savedDraftJson);
                        if (draft != null) { editPost = draft; StateHasChanged(); Notification.Notify(NotificationSeverity.Info, "Восстановлено", "Черновик загружен"); }
                    }
                    catch { }
                }
                else await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
            }

            autoSaveTimer = new Timer(15000);
            autoSaveTimer.Elapsed += async (sender, e) =>
            {
                await InvokeAsync(async () =>
                {
                    if (editPost != null && (!string.IsNullOrWhiteSpace(editPost.Title) || !string.IsNullOrWhiteSpace(editPost.Content)))
                    {
                        var json = JsonSerializer.Serialize(editPost);
                        await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
                        lastSavedTime = DateTime.Now;
                        StateHasChanged();
                    }
                });
            };
            autoSaveTimer.Start();
        }
    }

    private async Task OnSubmit(BlogPost post)
    {
        if (string.IsNullOrWhiteSpace(post.Slug)) post.Slug = SlugGenerator.Generate(post.Title);
        DbContext.Articles.Update(post);
        await DbContext.SaveChangesAsync();
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        FileService.RunGarbageCollectorInBackground();
        NavManager.NavigateTo("/admin/articles");
    }

    public void Dispose() => autoSaveTimer?.Dispose();

    private void RemoveAudio()
    {
        FileService.DeleteFile(editPost!.MainAudioUrl);
        editPost.MainAudioUrl = null;
        Notification.Notify(NotificationSeverity.Info, "Удалено", "Аудио откреплено и удалено с сервера");
    }

    private void RemoveVideo()
    {
        FileService.DeleteFile(editPost!.MainVideoUrl);
        editPost.MainVideoUrl = null;
        Notification.Notify(NotificationSeverity.Info, "Удалено", "Видео откреплено и удалено с сервера");
    }

    private void RemoveDocument()
    {
        FileService.DeleteFile(editPost!.FileAttachmentUrl);
        editPost.FileAttachmentUrl = null;
        Notification.Notify(NotificationSeverity.Info, "Удалено", "Документ откреплен и удален с сервера");
    }

    private void OnUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            if (editPost != null)
            {
                string? newUrl = null;
                if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
                else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();

                if (!string.IsNullOrEmpty(newUrl))
                {
                    FileService.DeleteFile(editPost.CoverImageUrl); // ОЧИСТКА МУСОРА
                    editPost.CoverImageUrl = newUrl;
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }

    private void OnAudioUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                FileService.DeleteFile(editPost!.MainAudioUrl); // ОЧИСТКА МУСОРА
                editPost.MainAudioUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Аудио загружено");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnVideoUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                FileService.DeleteFile(editPost!.MainVideoUrl); // ОЧИСТКА МУСОРА
                editPost.MainVideoUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Видео загружено");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnDocumentUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                FileService.DeleteFile(editPost!.FileAttachmentUrl); 
                editPost.FileAttachmentUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Успех", "Файл прикреплен!");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }
}