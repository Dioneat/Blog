@page "/admin/articles/edit/{Id:int}"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@implements IDisposable
@using System.Text.Json
@using System.Timers

@using Blog10.Utils
@using Radzen
@using Radzen.Blazor
@using Blog10.Models
@using Blog10.Data
@using Microsoft.EntityFrameworkCore

@inject NotificationService Notification
@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<PageTitle>Редактирование статьи</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Click="@(() => NavManager.NavigateTo("/admin/articles"))" />
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Редактирование статьи</RadzenText>
</RadzenStack>

@if (editPost == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="BlogPost" Data="@editPost" Submit="OnSubmit">
        <RadzenStack Gap="1.5rem">
            
            <RadzenFormField Text="Заголовок статьи">
                <RadzenTextBox @bind-Value="editPost.Title" Name="Title" style="width: 100%;" />
                <RadzenRequiredValidator Component="Title" Text="Заголовок обязателен" />
            </RadzenFormField>

            <RadzenFormField Text="Краткое описание">
                <RadzenTextArea @bind-Value="editPost.ShortDescription" style="width: 100%;" Rows="3" />
            </RadzenFormField>

            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3" class="rz-m-0">Титульное изображение (Обложка)</RadzenText>
                
                <RadzenUpload Url="api/upload/image" Accept="image/*" Complete="OnUploadComplete" style="width: 100%;" ChooseText="Выбрать другой файл..." />
                
                @if (!string.IsNullOrEmpty(editPost.CoverImageUrl))
                {
                    <div style="margin-top: 10px;">
                        <img src="@editPost.CoverImageUrl" alt="Предпросмотр обложки" style="max-width: 300px; border-radius: 8px; border: 1px solid var(--rz-secondary-light);" />
                    </div>
                }
            </RadzenStack>
            
            <RadzenStack Gap="1rem" class="rz-p-4 rz-background-color-warning-lighter rz-border-radius-2">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Аудио-вставка (например, пример звука)</RadzenText>
                <RadzenUpload Url="api/upload/audio" Accept="audio/*" Complete=@OnAudioUploadComplete ChooseText="Загрузить Аудио" style="width: 100%;" />
                @if (!string.IsNullOrEmpty(editPost.MainAudioUrl))
                {
                    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-color); padding: 15px; border-radius: 8px; border: 1px solid var(--rz-warning);">
                        <div style="display: flex; align-items: center; gap: 10px; color: var(--rz-warning-dark);">
                            <i class="fa-solid fa-headphones" style="font-size: 1.5rem;"></i>
                            <audio controls src="@editPost.MainAudioUrl" style="height: 30px;"></audio>
                        </div>
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => editPost.MainAudioUrl = null)" title="Открепить" />
                    </div>
                }
            </RadzenStack>

            <RadzenStack Gap="1rem" class="rz-p-4 rz-background-color-success-lighter rz-border-radius-2">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Видео-вставка (например, артикуляционная гимнастика)</RadzenText>
                <RadzenUpload Url="api/upload/video" Accept="video/*" Complete=@OnVideoUploadComplete ChooseText="Загрузить Видео" style="width: 100%;" />
                @if (!string.IsNullOrEmpty(editPost.MainVideoUrl))
                {
                    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-color); padding: 15px; border-radius: 8px; border: 1px solid var(--rz-success);">
                        <div style="display: flex; align-items: center; gap: 10px; color: var(--rz-success-dark);">
                            <i class="fa-solid fa-video" style="font-size: 1.5rem;"></i>
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">Видео прикреплено</RadzenText>
                        </div>
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => editPost.MainVideoUrl = null)" title="Открепить" />
                    </div>
                }
            </RadzenStack>
            
            <RadzenStack Gap="1rem" class="rz-p-4 rz-background-color-info-lighter rz-border-radius-2">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Прикрепить полезный материал (PDF)</RadzenText>
                <RadzenFormField Text="Название файла для пользователя" style="width: 100%;">
                    <RadzenTextBox @bind-Value="editPost.FileAttachmentName" Placeholder="Например: Памятка по артикуляции" style="width: 100%;" />
                </RadzenFormField>
                <RadzenUpload Url="api/upload/document" Accept="application/pdf" Complete=@OnDocumentUploadComplete ChooseText="Выбрать PDF-файл" style="width: 100%;" />
                @if (!string.IsNullOrEmpty(editPost.FileAttachmentUrl))
                {
                    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-color); padding: 15px; border-radius: 8px; border: 1px solid var(--rz-success); margin-top: 10px;">
                        <div style="display: flex; align-items: center; gap: 10px; color: var(--rz-success);">
                            <i class="fa-solid fa-file-pdf" style="font-size: 1.5rem;"></i>
                            <div>
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">Текущий файл: <strong>@(string.IsNullOrEmpty(editPost.FileAttachmentName) ? "Прикрепленный документ" : editPost.FileAttachmentName)</strong></RadzenText>
                                <a href="@editPost.FileAttachmentUrl" target="_blank" style="font-size: 0.8rem; color: var(--primary-color);">Проверить файл</a>
                            </div>
                        </div>
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => editPost.FileAttachmentUrl = null)" title="Открепить файл" />
                    </div>
                }
            </RadzenStack>
            <div class="row rz-p-4" style="background: var(--rz-base-background-color); border-radius: 8px; border: 1px solid #eee;">
                <div class="col-md-6">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить тест</RadzenText>
                    <RadzenDropDown TValue="int?" @bind-Value="editPost.QuizId"
                                    Data="@availableQuizzes" TextProperty="Title" ValueProperty="Id"
                                    Placeholder="Выберите тест из списка..." AllowClear="true" style="width: 100%;" />
                </div>
                <div class="col-md-6">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить карточки</RadzenText>
                    <RadzenDropDown TValue="int?" @bind-Value="editPost.FlashcardSetId"
                                    Data="@availableFlashcardSets" TextProperty="Name" ValueProperty="Id"
                                    Placeholder="Выберите набор карточек..." AllowClear="true" style="width: 100%;" />
                </div>
            </div>
            <div class="row">
                <div class="col-12 col-md-6 rz-mb-4 rz-mb-md-0">
                    <RadzenFormField Text="Категории статьи" style="width: 100%;">
                        <RadzenDropDown @bind-Value="editPost.Tags" Data="@availableTags" Multiple="true" AllowClear="true" Placeholder="Выберите одну или несколько..." Chips="true" style="width: 100%;" />
                    </RadzenFormField>
                </div>
                <div class="col-12 col-md-6">
                    <RadzenFormField Text="Дата и время публикации" style="width: 100%;">
                        <RadzenDatePicker @bind-Value="editPost.CreatedAt" ShowTime="true" ShowSeconds="false" DateFormat="dd.MM.yyyy HH:mm" style="width: 100%;" />
                    </RadzenFormField>
                </div>
            </div>

            <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Текст статьи</RadzenText>
            <RadzenHtmlEditor @bind-Value="editPost.Content" style="height: 500px;" UploadUrl="api/upload/image">
                <RadzenHtmlEditorUndo /><RadzenHtmlEditorRedo /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorBold /><RadzenHtmlEditorItalic /><RadzenHtmlEditorUnderline /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorAlignLeft /><RadzenHtmlEditorAlignCenter /><RadzenHtmlEditorAlignRight /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorFormatBlock /><RadzenHtmlEditorFontSize />
                <RadzenHtmlEditorImage /><RadzenHtmlEditorLink /><RadzenHtmlEditorSource />
            </RadzenHtmlEditor>

            <div class="rz-p-4 rz-mt-2" style="background: var(--rz-secondary-lighter); border-radius: 12px; border: 1px solid var(--rz-secondary-light);">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
                
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap" style="max-width: 100%;">
                    
                        <RadzenButton ButtonType="ButtonType.Submit" Size="ButtonSize.Large" Icon="save" Text="Обновить статью" ButtonStyle="ButtonStyle.Success" />
                    
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-p-2 rz-px-3" style="background: white; border-radius: 8px; border: 2px solid var(--rz-warning); max-width: 100%;">
                            <RadzenSwitch @bind-Value="editPost.IsDraft" Name="IsDraft" />
                            <RadzenLabel Text="Это черновик (скрыть)" Component="IsDraft" style="margin-left: 10px; font-weight: 700; cursor: pointer; color: var(--text-color); white-space: normal; line-height: 1.2;" />
                        </RadzenStack>

                    </RadzenStack>

                    @if (lastSavedTime.HasValue)
                    {
                        <span style="color: var(--text-secondary); font-size: 0.95rem; font-weight: 600;">
                            <i class="fa-solid fa-cloud-arrow-up" style="color: var(--rz-success);"></i> Автосохранение: @lastSavedTime.Value.ToString("HH:mm:ss")
                        </span>
                    }
                </RadzenStack>
            </div>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter]
    public int Id { get; set; }
    
    private List<string> availableTags = new();
    private BlogPost? editPost;
    List<Quiz> availableQuizzes = new();
    List<FlashcardSet> availableFlashcardSets = new();
    private Timer? autoSaveTimer;
    private DateTime? lastSavedTime;
    private string StorageKey => $"article_draft_edit_{Id}";

    protected override async Task OnInitializedAsync()
    {
        availableTags = await DbContext.Categories.Select(c => c.Name).ToListAsync();
        editPost = await DbContext.Articles.FindAsync(Id);
        availableQuizzes = await DbContext.Quizzes.ToListAsync();
        availableFlashcardSets = await DbContext.FlashcardSets.ToListAsync();
        if (editPost == null)
        {
            NavManager.NavigateTo("/admin/articles");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && editPost != null)
        {
            var savedDraftJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(savedDraftJson))
            {
                bool restore = await JSRuntime.InvokeAsync<bool>("confirm", "Найден несохраненный черновик этой статьи. Восстановить его?");
                if (restore)
                {
                    try
                    {
                        var draft = JsonSerializer.Deserialize<BlogPost>(savedDraftJson);
                        if (draft != null) { editPost = draft; StateHasChanged(); Notification.Notify(NotificationSeverity.Info, "Восстановлено", "Черновик загружен"); }
                    }
                    catch { }
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
                }
            }

            autoSaveTimer = new Timer(15000);
            autoSaveTimer.Elapsed += async (sender, e) =>
            {
                await InvokeAsync(async () =>
                {
                    if (editPost != null && (!string.IsNullOrWhiteSpace(editPost.Title) || !string.IsNullOrWhiteSpace(editPost.Content)))
                    {
                        var json = JsonSerializer.Serialize(editPost);
                        await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
                        lastSavedTime = DateTime.Now;
                        StateHasChanged();
                    }
                });
            };
            autoSaveTimer.Start();
        }
    }

    private async Task OnSubmit(BlogPost post)
    {
        if (string.IsNullOrWhiteSpace(post.Slug)) post.Slug = SlugGenerator.Generate(post.Title);

        DbContext.Articles.Update(post);
        await DbContext.SaveChangesAsync();

        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);

        NavManager.NavigateTo("/admin/articles");
    }

    public void Dispose()
    {
        autoSaveTimer?.Dispose();
    }

    private void OnUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            if (editPost != null)
            {
                if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) editPost.CoverImageUrl = urlElement.GetString() ?? string.Empty;
                else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) editPost.CoverImageUrl = lowerUrlElement.GetString() ?? string.Empty;
            }
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }

    private void OnAudioUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? uploadedUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) uploadedUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) uploadedUrl = lowerUrlElement.GetString();
            if (!string.IsNullOrEmpty(uploadedUrl)) { editPost.MainAudioUrl = uploadedUrl; Notification.Notify(NotificationSeverity.Success, "Аудио загружено"); }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnVideoUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? uploadedUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) uploadedUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) uploadedUrl = lowerUrlElement.GetString();
            if (!string.IsNullOrEmpty(uploadedUrl)) { editPost.MainVideoUrl = uploadedUrl; Notification.Notify(NotificationSeverity.Success, "Видео загружено"); }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnDocumentUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? uploadedUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) uploadedUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) uploadedUrl = lowerUrlElement.GetString();
            if (!string.IsNullOrEmpty(uploadedUrl)) { editPost.FileAttachmentUrl = uploadedUrl; Notification.Notify(NotificationSeverity.Success, "Успех", "Файл прикреплен!"); }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }
}