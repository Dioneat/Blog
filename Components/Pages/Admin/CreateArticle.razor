@page "/admin/articles/create"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using System.Text.Json
@using System.Timers
@using Blog10.Models
@using Blog10.Data
@using Blog10.Utils
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject Blog10.Services.FileService FileService
@inject Blog10.Services.VkSyncService VkService
@inject Blog10.Services.TelegramSyncService TgService
@inject NotificationService Notification
@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Написать статью</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Click="@(() => NavManager.NavigateTo("/admin/articles"))" />
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Новая статья</RadzenText>
</RadzenStack>

<RadzenTemplateForm TItem="BlogPost" Data="@newPost" Submit="OnSubmit">
    <RadzenStack Gap="1.5rem">
        
        @* --- 1. ОСНОВНАЯ ИНФОРМАЦИЯ --- *@
        <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-primary);">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-pen-nib rz-mr-2"></i> Основная информация</RadzenText>
            
            <RadzenStack Gap="1rem">
                <RadzenFormField Text="Заголовок статьи" style="width: 100%;">
                    <RadzenTextBox @bind-Value="newPost.Title" Name="Title" />
                    <RadzenRequiredValidator Component="Title" Text="Заголовок обязателен" />
                </RadzenFormField>

                <RadzenFormField Text="Краткое описание (для карточки на главной)" style="width: 100%;">
                    <RadzenTextArea @bind-Value="newPost.ShortDescription" Rows="3" />
                </RadzenFormField>

                <div class="row">
                    <div class="col-12 col-md-6 rz-mb-3 rz-mb-md-0">
                        <RadzenFormField Text="Категории статьи" style="width: 100%;">
                            <RadzenDropDown @bind-Value="newPost.Tags" Data="@availableTags" Multiple="true" AllowClear="true" Placeholder="Выберите категории..." Chips="true" />
                        </RadzenFormField>
                    </div>
                    <div class="col-12 col-md-6">
                        <RadzenFormField Text="Дата и время публикации" style="width: 100%;">
                            <RadzenDatePicker @bind-Value="newPost.CreatedAt" ShowTime="true" ShowSeconds="false" DateFormat="dd.MM.yyyy HH:mm" />
                        </RadzenFormField>
                    </div>
                </div>
            </RadzenStack>
        </RadzenCard>

        @* --- 2. МЕДИА И ФАЙЛЫ (СВОРАЧИВАЕМЫЙ БЛОК) --- *@
        <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-info);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween"
                         class="section-header-toggle" @onclick="() => isMediaExpanded = !isMediaExpanded">
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0"><i class="fa-solid fa-photo-film rz-mr-2"></i> Медиа и файлы</RadzenText>
                <i class="fa-solid fa-chevron-down chevron-icon @(isMediaExpanded ? "rotated" : "")"></i>
            </RadzenStack>
            
            <div class="expandable-section @(isMediaExpanded ? "expanded" : "")">
                <div class="row rz-pt-3">
                    <div class="col-12 col-lg-6 rz-mb-4">
                        <RadzenStack Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Subtitle2">Титульное изображение (Обложка)</RadzenText>
                            <RadzenUpload Url="api/upload/image" Accept="image/*" Complete="@OnUploadComplete" style="width: 100%;" ChooseText="Выбрать обложку..." />
                            @if (!string.IsNullOrEmpty(newPost.CoverImageUrl))
                            {
                                <div style="margin-top: 10px;">
                                    <img src="@newPost.CoverImageUrl" alt="Предпросмотр" style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; border: 1px solid var(--rz-secondary-light);" />
                                </div>
                            }
                        </RadzenStack>
                    </div>
                    
                    <div class="col-12 col-lg-6">
                        <RadzenStack Gap="1rem">
                            <div class="rz-p-3 rz-background-color-warning-lighter rz-border-radius-2">
                                <RadzenText TextStyle="TextStyle.Subtitle2">Аудио-вставка</RadzenText>
                                <RadzenUpload Url="api/upload/audio" Accept="audio/*" Complete=@OnAudioUploadComplete ChooseText="Загрузить Аудио" style="width: 100%;" />
                                @if (!string.IsNullOrEmpty(newPost.MainAudioUrl))
                                {
                                    <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                                        <audio controls src="@newPost.MainAudioUrl" style="height: 30px; width: 80%;"></audio>
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => newPost.MainAudioUrl = null)" title="Открепить" />
                                    </div>
                                }
                            </div>

                            <div class="rz-p-3 rz-background-color-success-lighter rz-border-radius-2">
                                <RadzenText TextStyle="TextStyle.Subtitle2">Видео-вставка</RadzenText>
                                <RadzenUpload Url="api/upload/video" Accept="video/*" Complete=@OnVideoUploadComplete ChooseText="Загрузить Видео" style="width: 100%;" />
                                @if (!string.IsNullOrEmpty(newPost.MainVideoUrl))
                                {
                                    <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                                        <span style="color: var(--rz-success-dark);"><i class="fa-solid fa-video rz-mr-2"></i> Видео прикреплено</span>
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => newPost.MainVideoUrl = null)" title="Открепить" />
                                    </div>
                                }
                            </div>
                        </RadzenStack>
                    </div>
                </div>

                <RadzenStack Gap="0.5rem" class="rz-mt-4 rz-p-3 rz-background-color-info-lighter rz-border-radius-2">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Полезный материал (PDF)</RadzenText>
                    <div class="row">
                        <div class="col-12 col-md-6 rz-mb-2 rz-mb-md-0">
                            <RadzenFormField Text="Название файла" style="width: 100%;">
                                <RadzenTextBox @bind-Value="newPost.FileAttachmentName" Placeholder="Например: Памятка по артикуляции" />
                            </RadzenFormField>
                        </div>
                        <div class="col-12 col-md-6">
                            <RadzenUpload Url="api/upload/document" Accept="application/pdf" Complete=@OnDocumentUploadComplete ChooseText="Выбрать PDF-файл" style="width: 100%; height: 40px;" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(newPost.FileAttachmentUrl))
                    {
                        <div class="rz-mt-2" style="display: flex; align-items: center; justify-content: space-between; background: white; padding: 10px; border-radius: 8px;">
                            <span style="color: var(--rz-info-dark);"><i class="fa-solid fa-file-pdf rz-mr-2"></i> @(string.IsNullOrEmpty(newPost.FileAttachmentName) ? "Документ прикреплен" : newPost.FileAttachmentName)</span>
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => newPost.FileAttachmentUrl = null)" title="Открепить" />
                        </div>
                    }
                </RadzenStack>
            </div>
        </RadzenCard>

        @* --- 3. ИНТЕРАКТИВЫ (СВОРАЧИВАЕМЫЙ БЛОК) --- *@
        <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-warning);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween"
                         class="section-header-toggle" @onclick="() => isInteractivesExpanded = !isInteractivesExpanded">
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0"><i class="fa-solid fa-gamepad rz-mr-2"></i> Интерактивы</RadzenText>
                <i class="fa-solid fa-chevron-down chevron-icon @(isInteractivesExpanded ? "rotated" : "")"></i>
            </RadzenStack>
            
            <div class="expandable-section @(isInteractivesExpanded ? "expanded" : "")">
                <div class="row rz-pt-3">
                    <div class="col-12 col-md-6 rz-mb-3 rz-mb-md-0">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить тест</RadzenText>
                        <RadzenDropDown TValue="int?" @bind-Value="newPost.QuizId"
                                        Data="@availableQuizzes" TextProperty="Title" ValueProperty="Id"
                                        Placeholder="Выберите тест из списка..." AllowClear="true" style="width: 100%;" />
                    </div>
                    <div class="col-12 col-md-6">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Прикрепить карточки</RadzenText>
                        <RadzenDropDown TValue="int?" @bind-Value="newPost.FlashcardSetId"
                                        Data="@availableFlashcardSets" TextProperty="Name" ValueProperty="Id"
                                        Placeholder="Выберите набор карточек..." AllowClear="true" style="width: 100%;" />
                    </div>
                </div>
            </div>
        </RadzenCard>

        @* --- 4. ТЕКСТ СТАТЬИ --- *@
        <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-success);">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-align-left rz-mr-2"></i> Текст статьи</RadzenText>
            <RadzenHtmlEditor @bind-Value="newPost.Content" style="height: 500px;" UploadUrl="api/upload/image">
                <RadzenHtmlEditorUndo /><RadzenHtmlEditorRedo /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorBold /><RadzenHtmlEditorItalic /><RadzenHtmlEditorUnderline /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorAlignLeft /><RadzenHtmlEditorAlignCenter /><RadzenHtmlEditorAlignRight /><RadzenHtmlEditorSeparator />
                <RadzenHtmlEditorFormatBlock /><RadzenHtmlEditorFontSize />
                <RadzenHtmlEditorImage /><RadzenHtmlEditorLink /><RadzenHtmlEditorSource />
            </RadzenHtmlEditor>
        </RadzenCard>

        @* --- 5. ПУБЛИКАЦИЯ --- *@
        <div class="rz-p-4 rz-mt-2">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
                
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                    <RadzenButton ButtonType="ButtonType.Submit" Size="ButtonSize.Large" Icon="save" Text="Сохранить и опубликовать" ButtonStyle="ButtonStyle.Success" />
                    
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-p-2 rz-px-3" style="background: white; border-radius: 8px; border: 2px solid var(--rz-warning);">
                        <RadzenSwitch @bind-Value="newPost.IsDraft" Name="IsDraft" />
                        <RadzenLabel Text="Скрыть (Черновик)" Component="IsDraft" style="margin-left: 10px; font-weight: 700; cursor: pointer; color: var(--text-color);" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-p-2 rz-px-3" style="background: #e5f0fa; border-radius: 8px; border: 2px solid #0077ff;">
                        <RadzenSwitch @bind-Value="postToVk" Name="PostToVk" />
                        <RadzenLabel Text="VK" Component="PostToVk" style="margin-left: 10px; font-weight: 700; cursor: pointer; color: #0077ff;" />
                        <i class="fa-brands fa-vk" style="margin-left: 8px; color: #0077ff; font-size: 1.2rem;"></i>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-p-2 rz-px-3" style="background: #e6f5ff; border-radius: 8px; border: 2px solid #0088cc;">
                        <RadzenSwitch @bind-Value="postToTg" Name="PostToTg" />
                        <RadzenLabel Text="Telegram" Component="PostToTg" style="margin-left: 10px; font-weight: 700; cursor: pointer; color: #0088cc;" />
                        <i class="fa-brands fa-telegram" style="margin-left: 8px; color: #0088cc; font-size: 1.2rem;"></i>
                    </RadzenStack>
                </RadzenStack>

                @if (lastSavedTime.HasValue)
                {
                    <span style="color: var(--text-secondary); font-size: 0.95rem; font-weight: 600; white-space: nowrap;">
                        <i class="fa-solid fa-cloud-arrow-up" style="color: var(--rz-success);"></i> Сохранено: @lastSavedTime.Value.ToString("HH:mm:ss")
                    </span>
                }
            </RadzenStack>
        </div>

    </RadzenStack>
</RadzenTemplateForm>

<style>
    /* Стили для плавного раскрытия */
    .section-header-toggle {
        cursor: pointer;
        user-select: none;
        transition: opacity 0.2s;
    }

        .section-header-toggle:hover {
            opacity: 0.8;
        }

    .chevron-icon {
        font-size: 1.2rem;
        color: var(--rz-text-disabled-color);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .chevron-icon.rotated {
            transform: rotate(180deg);
            color: var(--rz-primary);
        }

    .expandable-section {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease-in-out;
    }

        .expandable-section.expanded {
            max-height: 1500px; /* Достаточно большое значение для контента */
            opacity: 1;
            overflow: visible; /* Чтобы выпадающие списки (dropdown) не обрезались */
        }
</style>

@code {
    private bool isMediaExpanded = false;
    private bool isInteractivesExpanded = false;

    private bool postToTg = false;
    private bool postToVk = false;
    private BlogPost newPost = new BlogPost();
    private List<string> availableTags = new();
    
    private List<Quiz> availableQuizzes = new();
    private List<FlashcardSet> availableFlashcardSets = new();

    private Timer? autoSaveTimer;
    private DateTime? lastSavedTime;
    private const string StorageKey = "article_draft_create";

    protected override async Task OnInitializedAsync()
    {
        availableTags = await DbContext.Categories.Select(c => c.Name).ToListAsync();
        availableQuizzes = await DbContext.Quizzes.ToListAsync();
        availableFlashcardSets = await DbContext.FlashcardSets.ToListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedDraftJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(savedDraftJson))
            {
                bool restore = await JSRuntime.InvokeAsync<bool>("confirm", "У вас есть несохраненный черновик новой статьи. Хотите его восстановить?");
                if (restore)
                {
                    try
                    {
                        var draft = JsonSerializer.Deserialize<BlogPost>(savedDraftJson);
                        if (draft != null) { newPost = draft; StateHasChanged(); Notification.Notify(NotificationSeverity.Info, "Восстановлено", "Черновик загружен"); }
                    }
                    catch { }
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
                }
            }

            autoSaveTimer = new Timer(15000);
            autoSaveTimer.Elapsed += async (sender, e) =>
            {
                await InvokeAsync(async () =>
                {
                    if (!string.IsNullOrWhiteSpace(newPost.Title) || !string.IsNullOrWhiteSpace(newPost.Content))
                    {
                        var json = JsonSerializer.Serialize(newPost);
                        await JSRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
                        lastSavedTime = DateTime.Now;
                        StateHasChanged();
                    }
                });
            };
            autoSaveTimer.Start();
        }
    }

    private async Task OnSubmit(BlogPost post)
    {
        if (string.IsNullOrWhiteSpace(post.Slug)) post.Slug = SlugGenerator.Generate(post.Title);

        DbContext.Articles.Add(post);
        await DbContext.SaveChangesAsync();
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        FileService.RunGarbageCollectorInBackground();
        string baseUrl = NavManager.BaseUri.TrimEnd('/');
        string articleUrl = $"{baseUrl}/blog/{post.Id}/{post.Slug}";

        bool vkSuccess = true;
        bool tgSuccess = true;

        if (postToVk && !post.IsDraft)
        {
            var vkResult = await VkService.PublishToVkAsync(post.Title, post.ShortDescription ?? "", articleUrl);
            if (!vkResult.Success) { vkSuccess = false; Notification.Notify(NotificationSeverity.Error, "Ошибка ВК", vkResult.Message); }
        }

        if (postToTg && !post.IsDraft)
        {
            var tgResult = await TgService.PublishToTelegramAsync(post.Title, post.ShortDescription ?? "", articleUrl);
            if (!tgResult.Success) { tgSuccess = false; Notification.Notify(NotificationSeverity.Error, "Ошибка Telegram", tgResult.Message); }
        }

        if ((postToVk || postToTg) && !post.IsDraft && vkSuccess && tgSuccess)
        {
            Notification.Notify(NotificationSeverity.Success, "Успех!", "Статья сохранена на сайте и отправлена в соцсети!");
        }
        else if (!postToVk && !postToTg)
        {
            Notification.Notify(NotificationSeverity.Success, "Успех", "Статья сохранена на сайте.");
        }

        NavManager.NavigateTo("/admin/articles");
    }
    
    public void Dispose()
    {
        autoSaveTimer?.Dispose();
    }

    private void OnUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();

            if (!string.IsNullOrEmpty(newUrl))
            {
                if (!string.IsNullOrEmpty(newPost.CoverImageUrl))
                    FileService.DeleteFile(newPost.CoverImageUrl);
                    
                newPost.CoverImageUrl = newUrl;
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnAudioUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                if (!string.IsNullOrEmpty(newPost.MainAudioUrl)) FileService.DeleteFile(newPost.MainAudioUrl);
                
                newPost.MainAudioUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Аудио загружено");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnVideoUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                if (!string.IsNullOrEmpty(newPost.MainVideoUrl)) FileService.DeleteFile(newPost.MainVideoUrl);
                
                newPost.MainVideoUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Видео загружено");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }

    private void OnDocumentUploadComplete(UploadCompleteEventArgs args)
    {
        try
        {
            string? newUrl = null;
            if (args.JsonResponse.RootElement.TryGetProperty("Url", out var urlElement)) newUrl = urlElement.GetString();
            else if (args.JsonResponse.RootElement.TryGetProperty("url", out var lowerUrlElement)) newUrl = lowerUrlElement.GetString();
            
            if (!string.IsNullOrEmpty(newUrl))
            {
                if (!string.IsNullOrEmpty(newPost.FileAttachmentUrl)) FileService.DeleteFile(newPost.FileAttachmentUrl);
                
                newPost.FileAttachmentUrl = newUrl;
                Notification.Notify(NotificationSeverity.Success, "Успех", "Файл прикреплен!");
            }
        }
        catch (Exception ex) { Notification.Notify(NotificationSeverity.Error, "Ошибка загрузки", ex.Message); }
    }
}