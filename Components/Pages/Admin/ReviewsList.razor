@page "/admin/reviews"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Blog10.Data
@using Blog10.Models
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor
@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject DialogService DialogService

<PageTitle>Управление отзывами</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Отзывы</RadzenText>
    <RadzenButton Text="Добавить отзыв" Icon="add_comment" ButtonStyle="ButtonStyle.Primary" Click="@(() => NavManager.NavigateTo("/admin/reviews/create"))" />
</RadzenStack>

<RadzenDataGrid @ref="reviewsGrid" Data="@reviews" TItem="Review" AllowPaging="true" PageSize="10" AllowSorting="true">
    <Columns>
        <RadzenDataGridColumn TItem="Review" Title="Скриншот" Width="100px" Sortable="false" Filterable="false">
            <Template Context="review">
                <RadzenImage Path="@review.ImageUrl" style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover;" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="Review" Property="AuthorName" Title="Автор" />
        <RadzenDataGridColumn TItem="Review" Property="ChildInfo" Title="О ребенке" />
        
        <RadzenDataGridColumn TItem="Review" Property="IsDraft" Title="Статус" Width="130px">
            <Template Context="review">
                @if (review.IsDraft)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Черновик" />
                }
                else
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Опубликован" />
                }
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="Review" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="120px">
            <Template Context="review">
                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" 
                              Click="@(() => NavManager.NavigateTo($"/admin/reviews/edit/{review.Id}"))" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" 
                              Click="@(() => DeleteReview(review))" class="rz-ml-1" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private List<Review> reviews = new();
    
    private RadzenDataGrid<Review> reviewsGrid;

    protected override async Task OnInitializedAsync()
    {
        reviews = await DbContext.Reviews.OrderByDescending(r => r.CreatedAt).ToListAsync();
    }

    private async Task DeleteReview(Review review)
    {
        var result = await DialogService.Confirm($"Удалить отзыв от {review.AuthorName}?", "Подтверждение");
        if (result == true)
        {
            DbContext.Reviews.Remove(review);
            await DbContext.SaveChangesAsync();
            
            reviews.Remove(review);
            
            await reviewsGrid.Reload();
        }
    }
}