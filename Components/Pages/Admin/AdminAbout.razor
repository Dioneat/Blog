@page "/admin/about"
@rendermode InteractiveServer
@using System.Text.Json
@inject IAboutService AboutService
@inject NotificationService Notification
@inject IWebHostEnvironment Environment
@inject Blog10.Services.FileService FileService

<PageTitle>Конструктор контента | Логопед-педагог</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <i class="fa-solid fa-wand-magic-sparkles" style="font-size: 2rem; color: var(--rz-primary);"></i>
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Управление страницами</RadzenText>
</RadzenStack>

@if (model == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="AboutData" Data="@model" Submit="OnSave">
        <RadzenTabs RenderMode="TabRenderMode.Client" class="mobile-adaptive-tabs">
            <Tabs>
                <RadzenTabsItem Text="Главная: Приветствие">
                    <RadzenStack Gap="1.5rem" class="rz-p-2 rz-p-md-4">
                        <div class="rz-display-flex rz-justify-content-end">
                            <RadzenButton Text="Восстановить текст Hero" Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="RestoreHeroDefaults" class="rz-w-100 rz-w-md-auto" />
                        </div>
                        
                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-primary);">
                            <div class="row">
                                <div class="col-12 col-lg-7 rz-mb-4 rz-mb-lg-0">
                                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-heading rz-mr-2"></i> Тексты главного экрана</RadzenText>
                                    
                                    <RadzenFormField Text="Верхний тег (опыт)" style="width:100%" class="rz-mb-4">
                                        <RadzenTextBox @bind-Value="model.HeroTag" />
                                    </RadzenFormField>
                                    
                                    <RadzenFormField Text="Главный заголовок" style="width:100%" class="rz-mb-4">
                                        <RadzenTextArea @bind-Value="model.HeroTitle" Rows="2" />
                                    </RadzenFormField>
                                    
                                    <RadzenFormField Text="Описание (под заголовком)" style="width:100%">
                                        <RadzenTextArea @bind-Value="model.HeroDescription" Rows="4" />
                                    </RadzenFormField>
                                </div>
                                <div class="col-12 col-lg-5">
                                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-regular fa-image rz-mr-2"></i> Фотография</RadzenText>
                                    
                                    <div style="text-align: center; background: var(--rz-secondary-lighter); padding: 15px; border-radius: 12px; border: 1px dashed var(--rz-secondary);">
                                        <img src="@model.MainHeroImageUrl" style="width:100%; max-height:220px; object-fit:cover; border-radius:8px;" class="rz-mb-3 shadow-sm" />
                                        <InputFile OnChange="@(e => HandleUpload(e, "hero"))" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </RadzenCard>
                    </RadzenStack>
                </RadzenTabsItem>

                <RadzenTabsItem Text="Главная: Мой подход">
                    <RadzenStack Gap="1.5rem" class="rz-p-2 rz-p-md-4">
                        
                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-info);">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-layer-group rz-mr-2"></i> Настройка секции</RadzenText>
                            <div class="row">
                                <div class="col-12 col-md-6 rz-mb-3 rz-mb-md-0">
                                    <RadzenFormField Text="Заголовок секции" style="width:100%"><RadzenTextBox @bind-Value="model.AboutSectionTitle" /></RadzenFormField>
                                </div>
                                <div class="col-12 col-md-6">
                                    <RadzenFormField Text="Подзаголовок" style="width:100%"><RadzenTextBox @bind-Value="model.AboutSectionSubtitle" /></RadzenFormField>
                                </div>
                            </div>
                        </RadzenCard>

                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-warning);">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" class="rz-mb-4" Gap="1rem">
                                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0"><i class="fa-solid fa-cubes rz-mr-2"></i> Карточки подхода</RadzenText>
                                <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.5rem" class="rz-w-100 rz-w-md-auto">
                                    <RadzenButton Text="Добавить" Icon="add_circle" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="AddBlock" class="rz-w-100 rz-w-md-auto" />
                                    <RadzenButton Text="Восстановить" Icon="restore" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="RestoreDefaultBlocks" class="rz-w-100 rz-w-md-auto" />
                                </RadzenStack>
                            </RadzenStack>

                            @if (!aboutBlocks.Any())
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" class="rz-m-0">У вас пока нет ни одной карточки. Добавьте новую.</RadzenAlert>
                            }

                            @foreach (var block in aboutBlocks)
                            {
                                <div style="background: var(--rz-base-background-color); border: 1px solid var(--rz-secondary-light); border-radius: 10px; padding: 15px; margin-bottom: 15px; position: relative;">
                                    <div style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.ExtraSmall" Click="@(() => aboutBlocks.Remove(block))" title="Удалить" />
                                    </div>

                                    <div class="row rz-pt-3">
                                        <div class="col-12 col-md-3 col-lg-2 rz-mb-3 rz-mb-md-0 rz-text-align-center rz-text-align-md-left">
                                            <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-1" style="display:block;">Иконка</RadzenText>
                                            <RadzenDropDown @bind-Value="block.Icon" Data="@iconOptions" TextProperty="Key" ValueProperty="Value" style="width:100%" class="rz-mb-2">
                                                <Template Context="icon"><i class="fa-solid @icon.Value"></i> @icon.Key</Template>
                                            </RadzenDropDown>
                                            <div style="background: var(--rz-secondary-lighter); padding: 10px; border-radius: 8px; display: inline-block;">
                                                <i class="fa-solid @block.Icon fa-2x" style="color: var(--rz-primary);"></i>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-9 col-lg-10">
                                            <RadzenStack Gap="0.5rem">
                                                <RadzenTextBox @bind-Value="block.Title" Placeholder="Заголовок карточки" style="width:100%; font-weight: 600;" />
                                                <RadzenTextArea @bind-Value="block.Description" Placeholder="Описание подхода..." Rows="3" style="width:100%" />
                                            </RadzenStack>
                                        </div>
                                    </div>
                                </div>
                            }
                        </RadzenCard>

                    </RadzenStack>
                </RadzenTabsItem>

                <RadzenTabsItem Text="Счетчики и Цитата">
                    <RadzenStack Gap="1.5rem" class="rz-p-2 rz-p-md-4">
                        
                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-success);">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-chart-line rz-mr-2"></i> Статистика</RadzenText>
                            <div class="row">
                                <div class="col-12 col-md-4 rz-mb-3 rz-mb-md-0"><RadzenFormField Text="Лет опыта" style="width:100%"><RadzenTextBox @bind-Value="model.StatsExperience" /></RadzenFormField></div>
                                <div class="col-12 col-md-4 rz-mb-3 rz-mb-md-0"><RadzenFormField Text="Выпускников" style="width:100%"><RadzenTextBox @bind-Value="model.StatsChildren" /></RadzenFormField></div>
                                <div class="col-12 col-md-4"><RadzenFormField Text="Дипломов/Курсов" style="width:100%"><RadzenTextBox @bind-Value="model.StatsCertificates" /></RadzenFormField></div>
                            </div>
                        </RadzenCard>

                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-secondary);">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-quote-left rz-mr-2"></i> Главная цитата</RadzenText>
                            <RadzenStack Gap="1rem">
                                <RadzenFormField Text="Текст цитаты" style="width:100%">
                                    <RadzenTextArea @bind-Value="model.QuoteText" Rows="3" />
                                </RadzenFormField>
                                <RadzenFormField Text="Кто автор (подпись)" style="width:100%">
                                    <RadzenTextBox @bind-Value="model.QuoteAuthor" />
                                </RadzenFormField>
                            </RadzenStack>
                        </RadzenCard>

                    </RadzenStack>
                </RadzenTabsItem>

               <RadzenTabsItem Text="Страница Обо мне">
                    <RadzenStack Gap="1.5rem" class="rz-p-2 rz-p-md-4">
                        
                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-primary-dark);">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-address-card rz-mr-2"></i> Шапка страницы</RadzenText>
                            <div class="row align-items-center">
                                <div class="col-12 col-md-7 rz-mb-3 rz-mb-md-0">
                                    <RadzenFormField Text="Главный заголовок страницы (Имя)" style="width:100%">
                                        <RadzenTextBox @bind-Value="model.AboutPageTitle" />
                                    </RadzenFormField>
                                </div>
                                <div class="col-12 col-md-5">
                                    <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-1" style="display:block;">Фото профиля (круглое)</RadzenText>
                                    <div style="display:flex; align-items:center; gap: 15px; background: var(--rz-base-background-color); padding: 10px; border-radius: 8px;">
                                        <img src="@model.ProfileImageUrl" style="width:50px; height:50px; border-radius:50%; object-fit:cover; border: 2px solid var(--rz-primary);" />
                                        <InputFile OnChange="@(e => HandleUpload(e, "profile"))" class="form-control form-control-sm" />
                                    </div>
                                </div>
                            </div>
                        </RadzenCard>

                        <RadzenCard class="rz-p-3 rz-p-md-4" style="border-radius: 12px; border-left: 5px solid var(--rz-info-dark);">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-book-open rz-mr-2"></i> Моя история (Биография)</RadzenText>
                            <RadzenHtmlEditor @bind-Value="model.BioHtml" style="height: 350px;" />
                        </RadzenCard>

                        <div class="row">
                            <div class="col-12 col-xl-6 rz-mb-4 rz-mb-xl-0">
                                <RadzenCard class="rz-p-3 rz-p-md-4 h-100" style="border-radius: 12px; border-left: 5px solid var(--rz-warning-dark);">
                                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-graduation-cap rz-mr-2"></i> Образование</RadzenText>
                                    <RadzenHtmlEditor @bind-Value="model.EducationHtml" style="height: 300px;" />
                                </RadzenCard>
                            </div>
                            <div class="col-12 col-xl-6">
                                <RadzenCard class="rz-p-3 rz-p-md-4 h-100" style="border-radius: 12px; border-left: 5px solid var(--rz-success-dark);">
                                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-heart-circle-check rz-mr-2"></i> Принципы работы</RadzenText>
                                    <RadzenHtmlEditor @bind-Value="model.PrinciplesHtml" style="height: 300px;" />
                                </RadzenCard>
                            </div>
                        </div>

                    </RadzenStack>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>

        <div class="rz-p-3 rz-p-md-4 rz-mt-4 rz-mb-5" style="text-align: center;">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Сохранить изменения" Icon="save" 
                          ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Large" class="rz-w-100 rz-w-md-auto" style="min-width: 300px;" />
        </div>
    </RadzenTemplateForm>
}

<style>
    @@media (max-width: 768px) {
        .mobile-adaptive-tabs .rz-tabview-nav { display: flex; flex-direction: column; }
        .mobile-adaptive-tabs .rz-tabview-nav li { width: 100%; text-align: center; border-bottom: 1px solid var(--rz-secondary-light); }
    }
</style>

@code {
    private AboutData? model;
    private List<AboutBlock> aboutBlocks = new();

    private Dictionary<string, string> iconOptions = new() {
        { "Пазл", "fa-puzzle-piece" }, { "Мозг", "fa-brain" }, { "Сердце", "fa-hand-holding-heart" },
        { "Книга", "fa-book-open" }, { "Речь", "fa-comment-dots" }, { "Звезда", "fa-star" },
        { "Медаль", "fa-award" }, { "Улыбка", "fa-face-smile" }, { "Стетоскоп", "fa-stethoscope" }
    };

    protected override async Task OnInitializedAsync()
    {
        model = await AboutService.GetAboutDataAsync();
        if (model != null && !string.IsNullOrWhiteSpace(model.AboutBlocksJson))
        {
            try { aboutBlocks = JsonSerializer.Deserialize<List<AboutBlock>>(model.AboutBlocksJson) ?? new(); }
            catch { aboutBlocks = new(); }
        }
    }

    private void AddBlock() => aboutBlocks.Add(new AboutBlock { Icon = "fa-puzzle-piece" });

    private void RestoreHeroDefaults()
    {
        if (model == null) return;
        model.HeroTag = "Логопед-педагог • Опыт 12 лет";
        model.HeroTitle = "Говорим красиво и уверенно! Современная логопедия с любовью к детям.";
        model.HeroDescription = "Помогаю детям преодолеть речевые трудности через игру и доказательные методики.";
        Notification.Notify(NotificationSeverity.Info, "Тексты восстановлены", "Нажмите кнопку сохранения внизу.");
    }

    private void RestoreDefaultBlocks()
    {
        aboutBlocks.Clear();
        aboutBlocks.Add(new AboutBlock { Icon = "fa-puzzle-piece", Title = "Игровой формат", Description = "Забудьте о скучных занятиях. Мы играем и осваиваем сложные звуки." });
        aboutBlocks.Add(new AboutBlock { Icon = "fa-brain", Title = "Нейропсихология", Description = "Я работаю не только с языком, но и с мозгом." });
        aboutBlocks.Add(new AboutBlock { Icon = "fa-hand-holding-heart", Title = "Работа с семьей", Description = "Родитель — мой главный партнер в обучении." });
        Notification.Notify(NotificationSeverity.Info, "Блоки восстановлены", "Нажмите кнопку сохранения внизу.");
    }

    private async Task HandleUpload(InputFileChangeEventArgs e, string type)
    {
        var file = e.File;
        if (file == null) return;
        
        var folderPath = Path.Combine(Environment.WebRootPath, "uploads");
        Directory.CreateDirectory(folderPath);
        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var filePath = Path.Combine(folderPath, fileName);
        
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var fs = new FileStream(filePath, FileMode.Create);
        await stream.CopyToAsync(fs);

        string newUrl = $"/uploads/{fileName}";

        if (type == "hero") 
        {
            FileService.DeleteFile(model!.MainHeroImageUrl);
            model!.MainHeroImageUrl = newUrl;
        }
        else 
        {
            FileService.DeleteFile(model!.ProfileImageUrl);
            model!.ProfileImageUrl = newUrl;
        }
    }

    async Task OnSave()
    {
        model!.AboutBlocksJson = JsonSerializer.Serialize(aboutBlocks);
        await AboutService.UpdateAboutDataAsync(model);
        FileService.RunGarbageCollectorInBackground();
        Notification.Notify(NotificationSeverity.Success, "Успешно", "Все изменения на страницах сохранены!");
    }
}