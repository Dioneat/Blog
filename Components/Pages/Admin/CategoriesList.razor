@page "/admin/categories"
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Blog10.Data
@using Blog10.Models
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject AppDbContext DbContext
@inject DialogService DialogService

<PageTitle>Управление категориями</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">Категории блога</RadzenText>

<RadzenCard class="rz-mb-4" style="display: flex; gap: 10px; align-items: center;">
    <RadzenTextBox @bind-Value="newCategoryName" Placeholder="Название новой категории..." style="width: 300px;" />
    <RadzenButton Text="Добавить" Icon="add" ButtonStyle="ButtonStyle.Success" Click="@AddCategory" />
</RadzenCard>

<RadzenDataGrid Data="@categories" TItem="Category" AllowSorting="true">
    <Columns>
        <RadzenDataGridColumn TItem="Category" Property="Name" Title="Название категории" />
        
        <RadzenDataGridColumn TItem="Category" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="100px">
            <Template Context="cat">
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium"
                              Click="@(() => DeleteCategory(cat))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private List<Category> categories = new();
    private string newCategoryName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await DbContext.Categories.OrderBy(c => c.Name).ToListAsync();
    }

    private async Task AddCategory()
    {
        if (!string.IsNullOrWhiteSpace(newCategoryName))
        {
            
            if (!DbContext.Categories.Any(c => c.Name.ToLower() == newCategoryName.ToLower()))
            {
                DbContext.Categories.Add(new Category { Name = newCategoryName.Trim() });
                await DbContext.SaveChangesAsync();
                
                newCategoryName = ""; 
                await LoadCategories(); 
            }
        }
    }

    private async Task DeleteCategory(Category cat)
    {
        var result = await DialogService.Confirm($"Удалить категорию \"{cat.Name}\"?", "Подтверждение");
        if (result == true)
        {
            DbContext.Categories.Remove(cat);
            await DbContext.SaveChangesAsync();
            await LoadCategories();
        }
    }
}