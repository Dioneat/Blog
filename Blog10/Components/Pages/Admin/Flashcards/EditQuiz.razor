@page "/admin/quizzes/edit/{Id:int}"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Text.Json
@using Blog10.Models
@using Blog10.Data
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject AppDbContext DbContext
@inject NavigationManager NavManager
@inject NotificationService Notification

<PageTitle>Редактирование теста</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Click="@(() => NavManager.NavigateTo("/admin/quizzes"))" />
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Редактирование теста</RadzenText>
</RadzenStack>

@if (editQuiz == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenTemplateForm TItem="Quiz" Data="@editQuiz" Submit="OnSubmit">
        <RadzenStack Gap="2rem">
            
            <RadzenStack Gap="1rem" class="rz-p-4 rz-border-radius-2" style="border: 1px solid var(--rz-secondary-light); background: var(--rz-base-background-color);">
                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0" style="font-weight: bold;">Основная информация</RadzenText>
                
                <RadzenFormField Text="Заголовок теста">
                    <RadzenTextBox @bind-Value="editQuiz.Title" style="width: 100%;" />
                </RadzenFormField>

                <RadzenFormField Text="Подзаголовок">
                    <RadzenTextBox @bind-Value="editQuiz.Subtitle" style="width: 100%;" />
                </RadzenFormField>
            </RadzenStack>

            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">Вопросы</RadzenText>
                    <RadzenButton Text="Добавить вопрос" Icon="add_circle_outline" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="AddQuestion" />
                </RadzenStack>

                @if (editorQuestions.Count == 0)
                {
                    <RadzenText TextStyle="TextStyle.Body1" class="rz-color-danger">В тесте пока нет ни одного вопроса.</RadzenText>
                }
                else
                {
                    @for (int i = 0; i < editorQuestions.Count; i++)
                    {
                        var question = editorQuestions[i];
                        <RadzenCard class="rz-mt-2" style="border-left: 4px solid var(--rz-info);">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenFormField Text=$"Текст вопроса {i + 1}" style="width: 100%;">
                                    <RadzenTextBox @bind-Value="question.Text" style="width: 100%; font-weight: bold;" />
                                </RadzenFormField>
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => editorQuestions.Remove(question))" title="Удалить вопрос" />
                            </RadzenStack>

                            <RadzenStack Gap="0.5rem" class="rz-mt-3 rz-pl-4">
                                <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0">Варианты ответов:</RadzenText>
                                
                                @foreach (var answer in question.Answers)
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenTextBox @bind-Value="answer.Text" Placeholder="Текст ответа" style="flex: 1;" />
                                        
                                        <RadzenNumeric TValue="int" @bind-Value="answer.Score" Placeholder="Баллы" style="width: 100px;" title="Количество баллов за этот ответ" />
                                        <span style="font-size: 0.8rem; color: var(--rz-text-disabled-color);">баллов</span>
                                        
                                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => question.Answers.Remove(answer))" />
                                    </RadzenStack>
                                }
                                
                                <div>
                                    <RadzenButton Text="Добавить вариант ответа" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="@(() => question.Answers.Add(new QuizAnswer()))" />
                                </div>
                            </RadzenStack>
                        </RadzenCard>
                    }
                }
            </RadzenStack>

            <RadzenStack Gap="1rem" class="rz-p-4 rz-border-radius-2" style="border: 1px solid var(--rz-warning-light); background: #fffcf5;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">Результаты (Итоги)</RadzenText>
                    <RadzenButton Text="Добавить итог" Icon="add" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small" Click="@(() => editorResults.Add(new QuizResult()))" />
                </RadzenStack>
                
                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">Настройте сообщения, которые увидит пользователь в зависимости от набранных баллов.</RadzenText>

                @foreach (var res in editorResults)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
                        <RadzenNumeric TValue="int" @bind-Value="res.MinScore" Placeholder="От" style="width: 80px;" title="Минимальный балл" />
                        <span>-</span>
                        <RadzenNumeric TValue="int" @bind-Value="res.MaxScore" Placeholder="До" style="width: 80px;" title="Максимальный балл" />
                        
                        <RadzenTextBox @bind-Value="res.Message" Placeholder="Сообщение: Отличные новости! Развитие в норме..." style="flex: 1; min-width: 250px;" />
                        
                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => editorResults.Remove(res))" />
                    </RadzenStack>
                }
            </RadzenStack>

            <RadzenButton ButtonType="ButtonType.Submit" Text="Обновить тест" Icon="save" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Large" style="width: 200px;" />

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Quiz? editQuiz;
    private List<QuizQuestion> editorQuestions = new();
    private List<QuizResult> editorResults = new();

    protected override async Task OnInitializedAsync()
    {
        editQuiz = await DbContext.Quizzes.FindAsync(Id);

        if (editQuiz == null)
        {
            NavManager.NavigateTo("/admin/quizzes");
            return;
        }

        if (!string.IsNullOrEmpty(editQuiz.QuestionsJson))
        {
            try { editorQuestions = JsonSerializer.Deserialize<List<QuizQuestion>>(editQuiz.QuestionsJson) ?? new(); }
            catch { editorQuestions = new(); }
        }

        if (!string.IsNullOrEmpty(editQuiz.ResultsJson))
        {
            try { editorResults = JsonSerializer.Deserialize<List<QuizResult>>(editQuiz.ResultsJson) ?? new(); }
            catch { editorResults = new(); }
        }
    }

    private void AddQuestion()
    {
        editorQuestions.Add(new QuizQuestion
        {
            Answers = new List<QuizAnswer> { new QuizAnswer(), new QuizAnswer() }
        });
    }

    private async Task OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(editQuiz.Title)) 
        {
            Notification.Notify(NotificationSeverity.Warning, "Внимание", "Укажите заголовок теста");
            return;
        }

        // --- ДОБАВЛЕНА ПРОВЕРКА ---
        if (editorQuestions.Count == 0)
        {
            Notification.Notify(NotificationSeverity.Error, "Ошибка", "Тест должен содержать хотя бы один вопрос!");
            return;
        }

        if (editorQuestions.Any(q => string.IsNullOrWhiteSpace(q.Text) || q.Answers.Count < 2))
        {
            Notification.Notify(NotificationSeverity.Error, "Ошибка", "Заполните тексты всех вопросов и добавьте минимум 2 варианта ответа.");
            return;
        }
        // ---------------------------

        editQuiz.QuestionsJson = JsonSerializer.Serialize(editorQuestions);
        editQuiz.ResultsJson = JsonSerializer.Serialize(editorResults);

        DbContext.Quizzes.Update(editQuiz);
        await DbContext.SaveChangesAsync();
        
        Notification.Notify(NotificationSeverity.Success, "Успех", "Тест успешно сохранен!");
        NavManager.NavigateTo("/admin/quizzes");
    }
}