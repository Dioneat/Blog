@page "/admin"
@layout AdminLayout
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Blog10.Data
@using Blog10.Models
@using Radzen
@using Radzen.Blazor

@inject AppDbContext DbContext
@inject NavigationManager NavManager

<PageTitle>Дашборд | Админ-панель</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <i class="fa-solid fa-gauge-high" style="font-size: 2rem; color: var(--rz-primary);"></i>
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0 rz-ml-2">Обзор проекта</RadzenText>
</RadzenStack>

<div class="row rz-mb-4">
    <div class="col-12 col-md-6 col-lg-3 rz-mb-3 rz-mb-lg-0">
        <RadzenCard style="border-radius: 12px; border-bottom: 4px solid var(--rz-primary); height: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-color-secondary rz-m-0">Статьи</RadzenText>
                    <RadzenText TextStyle="TextStyle.H3" class="rz-m-0" style="font-weight: 800;">@publishedArticlesCount</RadzenText>
                    @if (draftArticlesCount > 0)
                    {
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-warning"><i class="fa-solid fa-pen-ruler"></i> + @draftArticlesCount в черновиках</RadzenText>
                    }
                </div>
                <div style="background: var(--rz-primary-lighter); padding: 15px; border-radius: 50%;">
                    <i class="fa-solid fa-file-lines fa-2x" style="color: var(--rz-primary);"></i>
                </div>
            </RadzenStack>
        </RadzenCard>
    </div>

    <div class="col-12 col-md-6 col-lg-3 rz-mb-3 rz-mb-lg-0">
        <RadzenCard style="border-radius: 12px; border-bottom: 4px solid var(--rz-success); height: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-color-secondary rz-m-0">Отзывы</RadzenText>
                    <RadzenText TextStyle="TextStyle.H3" class="rz-m-0" style="font-weight: 800;">@reviewsCount</RadzenText>
                </div>
                <div style="background: var(--rz-success-lighter); padding: 15px; border-radius: 50%;">
                    <i class="fa-solid fa-comments fa-2x" style="color: var(--rz-success);"></i>
                </div>
            </RadzenStack>
        </RadzenCard>
    </div>

    <div class="col-12 col-md-6 col-lg-3 rz-mb-3 rz-mb-lg-0">
        <RadzenCard style="border-radius: 12px; border-bottom: 4px solid var(--rz-warning); height: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-color-secondary rz-m-0">Интерактивы</RadzenText>
                    <RadzenText TextStyle="TextStyle.H3" class="rz-m-0" style="font-weight: 800;">@(quizzesCount + flashcardsCount)</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">Тестов: @quizzesCount | Карточек: @flashcardsCount</RadzenText>
                </div>
                <div style="background: var(--rz-warning-lighter); padding: 15px; border-radius: 50%;">
                    <i class="fa-solid fa-puzzle-piece fa-2x" style="color: var(--rz-warning);"></i>
                </div>
            </RadzenStack>
        </RadzenCard>
    </div>

    <div class="col-12 col-md-6 col-lg-3">
        <RadzenCard style="border-radius: 12px; border-bottom: 4px solid var(--rz-info); height: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <div>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-color-secondary rz-m-0">Категории</RadzenText>
                    <RadzenText TextStyle="TextStyle.H3" class="rz-m-0" style="font-weight: 800;">@categoriesCount</RadzenText>
                </div>
                <div style="background: var(--rz-info-lighter); padding: 15px; border-radius: 50%;">
                    <i class="fa-solid fa-tags fa-2x" style="color: var(--rz-info);"></i>
                </div>
            </RadzenStack>
        </RadzenCard>
    </div>
</div>

<div class="row rz-mb-4">
    <div class="col-12 col-xl-8 rz-mb-4 rz-mb-xl-0">
        <RadzenCard style="border-radius: 12px; height: 100%;">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-4"><i class="fa-solid fa-chart-line rz-mr-2" style="color: var(--rz-primary);"></i> Динамика публикаций (6 мес)</RadzenText>
            
            <RadzenChart>
                <RadzenColumnSeries Data="@monthlyStats" CategoryProperty="MonthName" Title="Статьи" LineType="LineType.Dashed" ValueProperty="Count" Fill="var(--rz-primary-lighter)" Stroke="var(--rz-primary)" StrokeWidth="2" />
                <RadzenColumnOptions Radius="5" />
                <RadzenValueAxis Min="0" Step="1">
                    <RadzenGridLines Visible="true" />
                    <RadzenAxisTitle Text="Количество статей" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        </RadzenCard>
    </div>

    <div class="col-12 col-xl-4">
        <RadzenCard style="border-radius: 12px; height: 100%;">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-4"><i class="fa-solid fa-chart-pie rz-mr-2" style="color: var(--rz-secondary);"></i> Структура контента</RadzenText>
            
            <RadzenChart>
                <RadzenDonutSeries Data="@contentDistribution" CategoryProperty="Category" ValueProperty="Count">
                    <ChildContent>
                        <RadzenSeriesDataLabels Visible="true" />
                    </ChildContent>
                    <TitleTemplate>
                        <div class="rz-donut-content">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-color-secondary">Всего</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@(publishedArticlesCount + draftArticlesCount + quizzesCount + flashcardsCount)</RadzenText>
                        </div>
                    </TitleTemplate>
                </RadzenDonutSeries>
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        </RadzenCard>
    </div>
</div>

<div class="row">
    <div class="col-12 col-xl-8 rz-mb-4">
        <RadzenCard style="border-radius: 12px; height: 100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-3">
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0"><i class="fa-regular fa-clock rz-mr-2"></i> Последние статьи</RadzenText>
                <RadzenButton Text="Все статьи" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => NavManager.NavigateTo("/admin/articles"))" />
            </RadzenStack>

            @if (recentArticles == null)
            {
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            }
            else if (!recentArticles.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="false">У вас пока нет ни одной статьи.</RadzenAlert>
            }
            else
            {
                <RadzenDataGrid Data="@recentArticles" TItem="BlogPost" AllowPaging="false">
                    <Columns>
                        <RadzenDataGridColumn TItem="BlogPost" Property="Title" Title="Заголовок">
                            <Template Context="post">
                                <div style="white-space: normal; line-height: 1.4;">
                                    <strong>@post.Title</strong>
                                    <br />
                                    <span style="font-size: 0.8rem; color: var(--rz-text-disabled-color);">@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="BlogPost" Title="Статус" Width="120px" TextAlign="TextAlign.Center">
                            <Template Context="post">
                                @if (post.IsDraft)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Черновик" />
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Опубликована" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="BlogPost" Title="Действия" Width="80px" TextAlign="TextAlign.Center">
                            <Template Context="post">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small"
                                              Click="@(() => NavManager.NavigateTo($"/admin/articles/edit/{post.Id}"))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    </div>

    <div class="col-12 col-xl-4 rz-mb-4">
        <RadzenCard style="border-radius: 12px; height: 100%;">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-bolt rz-mr-2" style="color: #ff9800;"></i> Быстрые действия</RadzenText>
            
            <RadzenStack Gap="1rem">
                <RadzenButton Text="Написать статью" Icon="draw" ButtonStyle="ButtonStyle.Primary" class="rz-w-100 rz-text-align-left"
                              Click="@(() => NavManager.NavigateTo("/admin/articles/create"))" />
                              
                <RadzenButton Text="Импорт из ВК" Icon="cloud_download" ButtonStyle="ButtonStyle.Info" class="rz-w-100 rz-text-align-left"
                              Click="@(() => NavManager.NavigateTo("/admin/articles/vk-sync"))" />
                              
                <RadzenButton Text="Добавить отзыв" Icon="add_comment" ButtonStyle="ButtonStyle.Success" class="rz-w-100 rz-text-align-left"
                              Click="@(() => NavManager.NavigateTo("/admin/reviews/create"))" />
                              
                <RadzenButton Text="Создать тест" Icon="quiz" ButtonStyle="ButtonStyle.Secondary" class="rz-w-100 rz-text-align-left"
                              Click="@(() => NavManager.NavigateTo("/admin/quizzes/create"))" />
                              
                <hr style="margin: 10px 0; border-top: 1px solid var(--rz-secondary-light);" />
                
                <RadzenButton Text="Проверить ошибки системы" Icon="monitor_heart" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" class="rz-w-100 rz-text-align-left"
                              Click="@(() => NavManager.NavigateTo("/admin/system"))" />
            </RadzenStack>
        </RadzenCard>
    </div>
</div>

@code {
    private int publishedArticlesCount = 0;
    private int draftArticlesCount = 0;
    private int reviewsCount = 0;
    private int categoriesCount = 0;
    private int quizzesCount = 0;
    private int flashcardsCount = 0;

    private List<BlogPost>? recentArticles;

    class DataItem { public string Category { get; set; } = ""; public int Count { get; set; } }
    class MonthStat { public string MonthName { get; set; } = ""; public int Count { get; set; } }
    
    private List<DataItem> contentDistribution = new();
    private List<MonthStat> monthlyStats = new();

    protected override async Task OnInitializedAsync()
    {
        publishedArticlesCount = await DbContext.Articles.CountAsync(a => !a.IsDraft);
        draftArticlesCount = await DbContext.Articles.CountAsync(a => a.IsDraft);
        reviewsCount = await DbContext.Reviews.CountAsync();
        categoriesCount = await DbContext.Categories.CountAsync();
        quizzesCount = await DbContext.Quizzes.CountAsync();
        flashcardsCount = await DbContext.FlashcardSets.CountAsync();

        recentArticles = await DbContext.Articles
            .AsNoTracking()
            .OrderByDescending(a => a.CreatedAt)
            .Take(5)
            .Select(a => new BlogPost
            {
                Id = a.Id,
                Title = a.Title,
                CreatedAt = a.CreatedAt,
                IsDraft = a.IsDraft
            })
            .ToListAsync();

        contentDistribution = new List<DataItem>
        {
            new DataItem { Category = "Статьи", Count = publishedArticlesCount + draftArticlesCount },
            new DataItem { Category = "Тесты", Count = quizzesCount },
            new DataItem { Category = "Карточки", Count = flashcardsCount }
        }.Where(d => d.Count > 0).ToList(); 

        var sixMonthsAgo = DateTime.Now.AddMonths(-5);
        var recentDates = await DbContext.Articles
            .AsNoTracking()
            .Where(a => a.CreatedAt >= new DateTime(sixMonthsAgo.Year, sixMonthsAgo.Month, 1))
            .Select(a => a.CreatedAt)
            .ToListAsync();

        monthlyStats = Enumerable.Range(0, 6)
            .Select(i => DateTime.Now.AddMonths(-i))
            .Select(d => new MonthStat
            {
                MonthName = d.ToString("MMM yy"), 
                Count = recentDates.Count(a => a.Year == d.Year && a.Month == d.Month)
            })
            .Reverse()
            .ToList();
    }
}