@page "/admin/settings/contacts"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Text.Json


@inject SettingsService SettingsService
@inject NotificationService Notification

<PageTitle>Настройки контактов</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
    <i class="fa-solid fa-address-book" style="font-size: 2rem; color: var(--rz-primary);"></i>
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0 rz-ml-2">Блок "Контакты"</RadzenText>
</RadzenStack>

<RadzenStack Gap="2rem" style="max-width: 800px;">

    @* --- ТЕКСТЫ --- *@
    <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-primary);">
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3"><i class="fa-solid fa-pen rz-mr-2"></i> Текстовое наполнение</RadzenText>
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="Заголовок блока" style="width: 100%;">
                <RadzenTextBox @bind-Value="title" style="width: 100%; font-weight: bold;" />
            </RadzenFormField>
            
            <RadzenFormField Text="Описание (подзаголовок)" style="width: 100%;">
                <RadzenTextArea @bind-Value="description" Rows="3" style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>
    </RadzenCard>

    @* --- ТЕЛЕФОНЫ --- *@
    <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-success);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
            <RadzenText TextStyle="TextStyle.H6" class="rz-m-0"><i class="fa-solid fa-phone rz-mr-2"></i> Номера телефонов</RadzenText>
            <RadzenButton Icon="add" Text="Добавить номер" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="AddPhone" />
        </RadzenStack>

        <RadzenStack Gap="0.5rem">
            @if (!phones.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" class="rz-m-0">Номера не добавлены. Блок телефонов на сайте будет скрыт.</RadzenAlert>
            }
            @foreach (var phone in phones.ToList())
            {
                <div style="display: flex; align-items: center; gap: 10px; background: var(--rz-base-background-color); padding: 10px; border-radius: 8px; border: 1px solid var(--rz-secondary-light);">
                    <i class="fa-solid fa-mobile-screen-button rz-color-secondary"></i>
                    <RadzenTextBox @bind-Value="phone.Value" Placeholder="+7 (999) 123-45-67" style="flex: 1;" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => RemovePhone(phone))" />
                </div>
            }
        </RadzenStack>
    </RadzenCard>

    @* --- СОЦСЕТИ --- *@
    <RadzenCard class="rz-p-4" style="border-radius: 12px; border-left: 5px solid var(--rz-info);">
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2"><i class="fa-solid fa-share-nodes rz-mr-2"></i> Социальные сети и мессенджеры</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-4 rz-color-secondary">Оставьте поле пустым, чтобы скрыть соответствующую кнопку на сайте.</RadzenText>
        
        <RadzenStack Gap="1rem">
            <div style="display: flex; align-items: center; gap: 15px;">
                <i class="fa-brands fa-whatsapp fa-2x" style="color: #25D366; width: 35px; text-align: center;"></i>
                <RadzenFormField Text="Ссылка на WhatsApp (https://wa.me/...)" style="flex: 1;">
                    <RadzenTextBox @bind-Value="waUrl" style="width: 100%;" />
                </RadzenFormField>
            </div>
            
            <div style="display: flex; align-items: center; gap: 15px;">
                <i class="fa-brands fa-telegram fa-2x" style="color: #0088cc; width: 35px; text-align: center;"></i>
                <RadzenFormField Text="Ссылка на Telegram (https://t.me/...)" style="flex: 1;">
                    <RadzenTextBox @bind-Value="tgUrl" style="width: 100%;" />
                </RadzenFormField>
            </div>

            <div style="display: flex; align-items: center; gap: 15px;">
                <i class="fa-brands fa-vk fa-2x" style="color: #0077ff; width: 35px; text-align: center;"></i>
                <RadzenFormField Text="Ссылка на ВКонтакте" style="flex: 1;">
                    <RadzenTextBox @bind-Value="vkUrl" style="width: 100%;" />
                </RadzenFormField>
            </div>
        </RadzenStack>
    </RadzenCard>

    <RadzenButton Text="Сохранить настройки" Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" Click="SaveSettings" IsBusy="@isSaving" class="rz-mb-5" />

</RadzenStack>

@code {
    public class PhoneItem { public string Value { get; set; } = ""; }

    private string title = "Давайте познакомимся!";
    private string description = "Первичная онлайн-консультация (20 мин) — бесплатно. Мы познакомимся, обсудим ваш запрос и наметим план действий.";
    private List<PhoneItem> phones = new();
    private string waUrl = "";
    private string tgUrl = "";
    private string vkUrl = "";
    
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        var savedTitle = await SettingsService.GetSettingAsync("Contact_Title");
        if (!string.IsNullOrEmpty(savedTitle)) title = savedTitle;

        var savedDesc = await SettingsService.GetSettingAsync("Contact_Desc");
        if (!string.IsNullOrEmpty(savedDesc)) description = savedDesc;

        var savedPhonesJson = await SettingsService.GetSettingAsync("Contact_Phones");
        if (!string.IsNullOrEmpty(savedPhonesJson))
        {
            try
            {
                var stringList = JsonSerializer.Deserialize<List<string>>(savedPhonesJson);
                if (stringList != null) phones = stringList.Select(s => new PhoneItem { Value = s }).ToList();
            }
            catch { phones.Add(new PhoneItem { Value = "+7 (999) 123-45-67" }); }
        }
        else
        {
            phones.Add(new PhoneItem { Value = "+7 (999) 123-45-67" });
        }

        waUrl = await SettingsService.GetSettingAsync("Contact_WaUrl") ?? "";
        tgUrl = await SettingsService.GetSettingAsync("Contact_TgUrl") ?? "";
        vkUrl = await SettingsService.GetSettingAsync("Contact_VkUrl") ?? "";
    }

    private void AddPhone() => phones.Add(new PhoneItem());
    private void RemovePhone(PhoneItem p) => phones.Remove(p);

    private async Task SaveSettings()
    {
        isSaving = true;
        StateHasChanged();

        await SettingsService.SetSettingAsync("Contact_Title", title, encrypt: false);
        await SettingsService.SetSettingAsync("Contact_Desc", description, encrypt: false);
        
        var phonesStrings = phones.Where(p => !string.IsNullOrWhiteSpace(p.Value)).Select(p => p.Value).ToList();
        await SettingsService.SetSettingAsync("Contact_Phones", JsonSerializer.Serialize(phonesStrings), encrypt: false);

        await SettingsService.SetSettingAsync("Contact_WaUrl", waUrl, encrypt: false);
        await SettingsService.SetSettingAsync("Contact_TgUrl", tgUrl, encrypt: false);
        await SettingsService.SetSettingAsync("Contact_VkUrl", vkUrl, encrypt: false);

        Notification.Notify(NotificationSeverity.Success, "Сохранено", "Контакты на главной странице обновлены!");
        isSaving = false;
    }
}