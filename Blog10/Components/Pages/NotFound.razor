@page "/not-found"
@inject NavigationManager NavManager

<PageTitle>Страница не найдена | Елена Тимофеева</PageTitle>

<div class="error-page-container">
    <div class="error-content fade-up">
        
        <div class="error-animation-box">
            <div class="pulse-circle"></div>
            <i class="fa-solid fa-magnifying-glass floating-icon"></i>
            <i class="fa-solid fa-question question-mark mark-1"></i>
            <i class="fa-solid fa-question question-mark mark-2"></i>
        </div>

        <h1 class="error-title">404</h1>
        <h2 class="error-subtitle">Ой! Страница потерялась...</h2>
        
        <p class="error-text">
            Возможно, она была удалена, переименована или вы просто ошиблись в адресе. 
            Ничего страшного, давайте вернемся на главную!
        </p>

        <div class="error-actions">
            <a href="/" class="cta-btn">
                <i class="fa-solid fa-house rz-mr-2"></i> На главную
            </a>
            <a href="/blog" class="cta-btn outline">
                <i class="fa-solid fa-book-open rz-mr-2"></i> Почитать блог
            </a>
        </div>
    </div>
</div>

<style>
    .error-page-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background: linear-gradient(135deg, var(--bg-secondary) 0%, #ffffff 100%);
        overflow: hidden;
    }

    .error-content {
        text-align: center;
        max-width: 600px;
        position: relative;
        z-index: 2;
    }

    .error-animation-box {
        position: relative;
        width: 200px;
        height: 200px;
        margin: 0 auto 30px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pulse-circle {
        position: absolute;
        width: 150px;
        height: 150px;
        background: var(--accent-light);
        border-radius: 50%;
        animation: pulse 3s infinite ease-in-out;
        z-index: 1;
    }

    .floating-icon {
        font-size: 5rem;
        color: var(--primary-color);
        position: relative;
        z-index: 2;
        animation: float 4s infinite ease-in-out;
        text-shadow: 0 10px 20px rgba(27, 84, 245, 0.2);
    }

    .question-mark {
        position: absolute;
        font-size: 2rem;
        color: #ff9800;
        opacity: 0;
        z-index: 3;
    }
    .mark-1 { top: 20px; right: 30px; animation: pop 3s infinite 0.5s ease-in-out; }
    .mark-2 { bottom: 30px; left: 20px; animation: pop 3s infinite 1.5s ease-in-out; font-size: 1.5rem; color: var(--secondary-color); }

    .error-title {
        font-size: 6rem;
        font-weight: 900;
        background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
        line-height: 1;
        letter-spacing: -2px;
    }

    .error-subtitle {
        font-size: 2rem;
        color: var(--text-color);
        margin-bottom: 15px;
        font-weight: 800;
    }

    .error-text {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 40px;
        line-height: 1.6;
    }

    .error-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    @@keyframes float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(5deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }

    @@keyframes pulse {
        0% { transform: scale(0.9); opacity: 0.5; }
        50% { transform: scale(1.1); opacity: 0.8; }
        100% { transform: scale(0.9); opacity: 0.5; }
    }

    @@keyframes pop {
        0% { transform: scale(0) translateY(10px); opacity: 0; }
        50% { transform: scale(1) translateY(0); opacity: 1; }
        100% { transform: scale(0) translateY(-10px); opacity: 0; }
    }

    @@media (max-width: 768px) {
        .error-title { font-size: 4.5rem; }
        .error-subtitle { font-size: 1.5rem; }
        .error-animation-box { width: 150px; height: 150px; }
        .floating-icon { font-size: 4rem; }
    }
</style>