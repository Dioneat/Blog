@using System.Text.Json
@using Blog10.Services
@inject IAboutService AboutService

<section id="about" class="section section-bg-secondary">
    <div class="section-header fade-up">
        <h2 class="section-title">@data?.AboutSectionTitle</h2>
        <p class="section-subtitle">@data?.AboutSectionSubtitle</p>
    </div>

    <div class="grid-3">
        @if (blocks != null)
        {
            @foreach (var block in blocks)
            {
                <div class="card fade-up">
                    <div class="about-card-icon">
                        <i class="fa-solid @block.Icon fa-2x"></i>
                    </div>
                    <h3>@block.Title</h3>
                    <p>@block.Description</p>
                </div>
            }
        }
    </div>
</section>

@code {
    private Blog10.Models.AboutData? data;
    private List<Blog10.Models.AboutBlock>? blocks = new(); 

    protected override async Task OnInitializedAsync()
    {
        data = await AboutService.GetAboutDataAsync();
        
        if (data != null)
        {
            if (!string.IsNullOrWhiteSpace(data.AboutBlocksJson))
            {
                try
                {
                    blocks = JsonSerializer.Deserialize<List<Blog10.Models.AboutBlock>>(data.AboutBlocksJson) ?? new();
                }
                catch
                {
                    blocks = new(); 
                }
            }
        }
    }
}