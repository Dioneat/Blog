@page "/blog"
@using Blog10.Models
@using Blog10.Services
@inject NavigationManager NavManager
@rendermode InteractiveServer

@inject IBlogService BlogService

<PageTitle>Блог логопеда</PageTitle>

<section class="section" style="padding-top: 120px; min-height: 100vh;">
    <div class="container">
        <div class="section-header fade-up">
            <h1 class="section-title">Все статьи</h1>
        </div>

        @if (allPosts.Count == 0)
        {
            @* --- ЗАГЛУШКА: СТАТЕЙ ВООБЩЕ НЕТ --- *@
            <div class="empty-state fade-up">
                <div class="empty-icon-box">
                    <i class="fa-solid fa-pen-nib"></i>
                </div>
                <h2>Блог в процессе наполнения</h2>
                <p>Я уже готовлю для вас интересные и полезные материалы по логопедии. Загляните сюда чуть позже!</p>
                <a href="/#contacts" class="cta-btn">Записаться на консультацию</a>
            </div>
        }
        else
        {
            @if (allCategories.Any())
            {
                <div class="category-filters fade-up">
                    <button class="filter-btn @(string.IsNullOrEmpty(Category) ? "active" : "")" @onclick="() => SelectCategory(null)">Все статьи</button>
                    @foreach (var cat in allCategories)
                    {
                        <button class="filter-btn @(Category == cat ? "active" : "")" @onclick="() => SelectCategory(cat)">@cat</button>
                    }
                </div>
            }

            @if (filteredPosts.Any())
            {
                <div class="grid-3">
                    @foreach (var post in filteredPosts.Take(visibleCount))
                    {
                        <div class="card blog-card fade-up">
                            <div class="blog-thumb">
                                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                                {
                                    <img src="@post.CoverImageUrl" alt="@post.Title">
                                }
                                else
                                {
                                    <div class="blog-placeholder">
                                        <i class="fa-solid fa-shapes placeholder-icon"></i>
                                        <span class="placeholder-text">Статья</span>
                                    </div>
                                }
                            
                                @if (post.Tags != null && post.Tags.Any())
                                {
                                    <div class="blog-card-tags">
                                        @foreach (var tag in post.Tags.Take(3))
                                        {
                                            <span class="blog-card-tag">@tag</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="blog-content">
                                <div class="blog-meta">
                                    <span><i class="fa-regular fa-calendar"></i> @post.CreatedAt.ToString("dd MMM yyyy")</span>
                                    <span><i class="fa-regular fa-clock"></i> ~@post.ReadTime мин.</span>
                                </div>
                                <h3 style="margin-bottom: 10px;">@post.Title</h3>
                                <p style="color: var(--text-secondary); margin-bottom: 20px;">@post.ShortDescription</p>
                                <button @onclick="() => GoToArticle(post)" class="blog-link" style="background: none; border: none; cursor: pointer; padding: 0;">
                                    Читать статью <i class="fa-solid fa-arrow-right-long"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                @if (visibleCount < filteredPosts.Count)
                {
                    <div class="load-more-container fade-up">
                        <button class="cta-btn outline" @onclick="LoadMore">
                            <i class="fa-solid fa-rotate-right"></i> Загрузить еще
                        </button>
                        <div class="load-more-info">
                            Показано @Math.Min(visibleCount, filteredPosts.Count) из @filteredPosts.Count
                        </div>
                    </div>
                }
            }
            else
            {
                @* --- ЗАГЛУШКА: В ВЫБРАННОЙ КАТЕГОРИИ ПУСТО --- *@
                <div class="empty-state fade-up" style="max-width: 600px; padding: 50px 20px;">
                    <div class="empty-icon-box" style="width: 80px; height: 80px; font-size: 2.5rem; margin-bottom: 15px;">
                        <i class="fa-regular fa-folder-open"></i>
                    </div>
                    <h3 style="margin-bottom: 10px;">В этой категории пока нет статей</h3>
                    <p style="margin-bottom: 20px;">Попробуйте выбрать другую тему.</p>
                    <button class="cta-btn outline" @onclick="() => SelectCategory(null)">Показать все статьи</button>
                </div>
            }
        }
    </div>
</section>

<style>
    /* Стили для красивых заглушек */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: var(--card-bg);
        border-radius: 30px;
        border: 2px dashed var(--accent-light);
        max-width: 800px;
        margin: 0 auto;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
    }
    .empty-icon-box {
        width: 100px;
        height: 100px;
        background: var(--accent-light);
        color: var(--primary-color);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        margin: 0 auto 25px;
    }
    .empty-state h2 { color: var(--text-color); margin-bottom: 15px; font-size: 2.2rem; }
    .empty-state p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 30px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }
    
    .category-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin-bottom: 50px;
    }

    .filter-btn {
        background: var(--card-bg);
        border: 2px solid var(--accent-light);
        color: var(--text-secondary);
        padding: 8px 22px;
        border-radius: 50px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        font-size: 0.95rem;
    }

    .filter-btn:hover {
        border-color: var(--primary-color);
        color: var(--primary-color);
        transform: translateY(-2px);
    }

    .filter-btn.active {
        background: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
        box-shadow: var(--shadow-sm);
    }

    .blog-card-tags {
        position: absolute;
        top: 15px;
        left: 15px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        z-index: 2;
    }

    .blog-card-tag {
        background: rgba(255, 255, 255, 0.95);
        color: var(--primary-color);
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        backdrop-filter: blur(4px);
    }

    .load-more-container {
        text-align: center;
        margin-top: 50px;
        padding-top: 20px;
    }

    .outline {
        background: transparent !important;
        border: 2px solid var(--primary-color) !important;
        color: var(--primary-color) !important;
        box-shadow: none !important;
    }
    .outline:hover {
        background: var(--primary-color) !important;
        color: white !important;
    }

    .load-more-info {
        margin-top: 15px;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Category { get; set; }

    private List<BlogPost> allPosts = new();
    private List<BlogPost> filteredPosts = new();
    private List<string> allCategories = new();

    private int pageSize = 6;
    private int visibleCount = 6;

    protected override async Task OnInitializedAsync()
    {
        allPosts = await BlogService.GetPublishedPostsAsync();
        
        allCategories = allPosts
            .Where(p => p.Tags != null)
            .SelectMany(p => p.Tags)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Distinct()
            .OrderBy(t => t)
            .ToList();
            
        ApplyFilter();
    }

    protected override void OnParametersSet()
    {
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(Category))
        {
            filteredPosts = allPosts;
        }
        else
        {
            filteredPosts = allPosts
                .Where(p => p.Tags != null && p.Tags.Contains(Category, StringComparer.OrdinalIgnoreCase))
                .ToList();
        }
        
        visibleCount = pageSize;
    }

    private void LoadMore()
    {
        visibleCount += pageSize;
    }

    private void SelectCategory(string? category)
    {
        if (string.IsNullOrEmpty(category))
            NavManager.NavigateTo("/blog");
        else
            NavManager.NavigateTo($"/blog?Category={Uri.EscapeDataString(category)}");
    }

    private void GoToArticle(BlogPost post)
    {
        string url = string.IsNullOrWhiteSpace(post.Slug)
            ? $"/blog/{post.Id}"
            : $"/blog/{post.Id}/{post.Slug}";
            
        NavManager.NavigateTo(url, forceLoad: true);
    }
}