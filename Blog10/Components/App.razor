<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <meta name="description" content="Частная логопедическая практика Елены Тимофеевой. Запуск речи, постановка звуков, подготовка к школе." />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <ResourcePreloader />
    
    <link rel="stylesheet" href="/_content/Radzen.Blazor/css/material-base.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Blog10.styles.css"]" />

    <ImportMap />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <div id="components-reconnect-modal" class="components-reconnect-hide">
        <div class="reconnect-dialog show-dialog">
            <i class="fa-solid fa-rotate custom-spin" style="color: var(--primary-color, #1b54f5); font-size: 1.5rem; margin-bottom: 10px;"></i>   
            <h5 style="margin: 0; font-weight: 700; font-size: 1.1rem;">Восстановление связи...</h5>
            <p style="margin: 5px 0 0; font-size: 0.9rem; color: #6c757d;">Пожалуйста, подождите</p>
        </div>

        <div class="reconnect-dialog failed-dialog">
            <i class="fa-solid fa-wifi" style="color: #dc3545; font-size: 1.5rem; margin-bottom: 10px;"></i>
            <h5 style="margin: 0; font-weight: 700; font-size: 1.1rem;">Связь потеряна</h5>
            <p style="margin: 5px 0 15px; font-size: 0.9rem; color: #6c757d;">Проверьте подключение к интернету.</p>
            <button onclick="window.Blazor.reconnect()" class="cta-btn" style="padding: 8px 20px; font-size: 0.9rem;">Повторить</button>
        </div>

        <div class="reconnect-dialog rejected-dialog">
            <i class="fa-solid fa-server" style="color: #dc3545; font-size: 1.5rem; margin-bottom: 10px;"></i>
            <h5 style="margin: 0; font-weight: 700; font-size: 1.1rem;">Сессия завершена</h5>
            <p style="margin: 5px 0 15px; font-size: 0.9rem; color: #6c757d;">Сервер был обновлен.</p>
            <button onclick="location.reload()" class="cta-btn outline" style="padding: 8px 20px; font-size: 0.9rem;">Обновить страницу</button>
        </div>
    </div>
    <script src="/_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="/scripts.js"></script>
    <script src="/@Assets["_framework/blazor.web.js"]"></script>
</body>
</html>